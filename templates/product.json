      "name": "Product Info",
      "settings": {
        "width": "page",
        "image": "shopify://shop_images/8-chef-knife-pin-series-x020-4936499.jpg",
        "header_type": "left",
        "heading": "<h2>Crafted in Yangjiang, the Capital of Knives</h2>",
        "content": "<p>Every Xinzuo knife is forged in Yangjiang, China — a city with over 1,400 years of blade-making tradition. Using premium steels sourced from Japan, Germany, and China, each blade undergoes vacuum heat treatment and precision grinding to deliver professional-grade performance.</p>",
        "icon_block_state": true,
        "first_num": "3",
        "second_num": "3",
        "color_scheme": "scheme-5",
        "padding_top": 80,
