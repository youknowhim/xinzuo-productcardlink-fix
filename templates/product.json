    "product_info2_8biKrj": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "1,400 YEARS OF BLADE-MAKING TRADITION",
        "heading_content": "<h2>World-Class Steel, Australian Standards</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "Xinzuo partners with the finest steel mills and the most skilled blade makers in Yangjiang to create knives that rival European and Japanese brands at a fraction of the price. No legacy-brand markups — just exceptional knives.",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "<h2>THE XINZUO DIFFERENCE</h2>",
        "footer_right": "<p>Every knife comes in a premium gift box, backed by a lifetime warranty, and supported by an Australian team. We've cut out the middlemen so you get professional-grade knives directly from the makers.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_eVwTgB": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "full",
        "heading_title": "",
        "heading_content": "<h2>Premium Materials,<br/>Honest Pricing</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "second",
        "footer_left": "<p>From German 1.4116 stainless steel to Japanese Damascus, every Xinzuo series uses materials chosen for performance and durability. We don't use cheap filler steels or low-grade handle materials. Every component earns its place.</p>",
        "footer_right": "<h2>Sharp</h2><p>15° edge angle for effortless, clean cuts every time.</p><h2>Durable</h2><p>Heat-treated steel that holds its edge through heavy daily use.</p><h2>Beautiful</h2><p>Premium handles and finishes that look as good as they perform.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_GjRq8Y": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "",
        "heading_content": "<h2>Why Choose<br/>Xinzuo</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "third",
        "footer_left": "<p>We're a 100% Australian-owned company that sources directly from the best knife makers in the world. No retail markups, no distributor fees — just the best knives at honest prices, shipped fast from our Australian warehouse.</p>",
        "footer_right": "<p>Every knife is backed by Australian Consumer Law, a lifetime warranty against manufacturing defects, and a 30-day no-questions return policy. We've got your back.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
