    "best_reviews_JmRvws": {
      "type": "best-reviews",
      "blocks": {
        "br_block_4": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Awesome knife",
            "body": "Love this knife so much I got one for my son for his birthday and he loves it too. He is cooking much better and has less hand fatigue. Will be getting my other son one for his birthday in January.",
            "name": "Michael T.",
            "location": "Adelaide, SA",
            "verified": true
          }
        },
        "br_block_1": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Amazing! Best purchase!",
            "body": "Arrived within a couple of days of ordering. The sharpness is a lifesaver. I actually thought my old knives were decent before Xinzuo, but I was so wrong. I've had such effortless cuts since having it. The Damascus pattern is absolutely beautiful and the handle feels premium. Would buy again in a heartbeat.",
            "name": "Sarah M.",
            "location": "Melbourne, VIC",
            "verified": true
          }
        },
        "br_block_2": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Simply the best",
            "body": "Just upgraded from a basic knife set and the difference is night and day. Still as sharp as day one after months of daily use.",
            "name": "James K.",
            "location": "Brisbane, QLD",
            "verified": true
          }
        },
        "br_block_3": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Self-care every single night!",
            "body": "This has been the best investment in self-care — from delivery to unpacking and setting up, to the first night's cook. Comfortable, supportive, and precise makes this the best investment in one's culinary journey and mental health!",
            "name": "Emily R.",
            "location": "Perth, WA",
            "verified": true
          }
        },
        "br_block_5": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Should have bought it years ago!",
            "body": "I have suffered with very bad wrist problems for the past 5 years. Every morning waking up with this knife I feel like I did when I was 20! LOVE this knife. The ergonomic handle is a game changer and the balance is absolutely perfect.",
            "name": "David L.",
            "location": "Sydney, NSW",
            "verified": true
          }
        },
        "br_block_6": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Stunning craftsmanship",
            "body": "Every detail is impeccable. From the Damascus pattern to the handle finish, you can tell this was made with care.",
            "name": "Rachel W.",
            "location": "Gold Coast, QLD",
            "verified": true
          }
        },
        "br_block_7": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "Exceeded all expectations",
            "body": "I was sceptical about ordering knives online but wow. The edge is razor sharp out of the box and the handle feels incredible in the hand. The weight distribution is spot on — it practically does the work for you. Already ordered a second one for my brother. Xinzuo has earned a customer for life.",
            "name": "Tom H.",
            "location": "Hobart, TAS",
            "verified": true
          }
        },
        "br_block_8": {
          "type": "review",
          "settings": {
            "rating": 5,
            "title": "A real game changer",
            "body": "Prep time is halved, cuts are cleaner, and it just feels right in the hand. Cannot recommend enough.",
            "name": "Anna C.",
            "location": "Canberra, ACT",
            "verified": true
          }
        }
      },
