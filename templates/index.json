        "block_HigAQt": {
          "type": "block",
          "settings": {
            "heading": "Precision in Every Cut",
            "content": "<p>From fine herbs to tough meats, Xinzuo knives cut flawlessly. The craftsmanship inspires confidence with every slice.</p>",
