          "settings": {
            "heading": "The Chef’s Perfect Edge",
            "content": "<p>I’ve been cooking for years, and good knives make all the difference. With Xinzuo, every slice feels smooth, precise, and controlled. </p>",
            "customer": "Chef Daniel Richter",
            "location": "— Head Chef, Bellevue Kitchen & Bar Hamburg, Germany"
