    "product_info_SA01": {
      "type": "product-info",
      "blocks": {
        "icon_SA01_1": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-edge.svg",
            "content": "<p><strong>Leather Strop</strong><br/>Polishes and realigns the very tip of the cutting edge to a mirror finish. The final step to a truly razor-sharp blade.</p>"
          }
        },
        "icon_SA01_2": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-clock.svg",
            "content": "<p><strong>Honing Rod</strong><br/>Straightens the microscopic edge alignment without removing any metal. Quick daily maintenance that keeps your knife cutting like new.</p>"
          }
        },
        "block_SA01_1": {
          "type": "block",
          "settings": {
            "header": "Daily Ritual",
            "content": "30 Seconds, Every Time",
            "footer": "A few passes on a strop or honing rod before each cooking session keeps your edge razor-sharp and your cuts effortless."
          }
        },
        "block_SA01_2": {
          "type": "block",
          "settings": {
            "header": "Extends Sharpness",
            "content": "Months Between Sharpenings",
            "footer": "Proper daily maintenance can triple the time between full whetstone sessions — saving you time and preserving your blade."
          }
        },
        "block_SA01_3": {
          "type": "block",
          "settings": {
            "header": "Easy Technique",
            "content": "No Special Skills",
            "footer": "Draw the blade away from the edge at a shallow angle. Five passes per side. Done. Anyone can master it in minutes."
          }
        }
      },
      "block_order": [
        "icon_SA01_1",
        "icon_SA01_2",
        "block_SA01_1",
        "block_SA01_2",
        "block_SA01_3"
      ],
      "name": "Product Info",
      "settings": {
        "width": "page",
        "header_type": "left",
        "heading": "<h2>Maintain Your Edge Between Sharpenings</h2>",
        "content": "<p>A sharp knife is a safe knife. Stropping realigns the micro-edge after every use. Honing straightens bent edges from daily cutting. Together, they extend the time between full whetstone sharpenings from weeks to months.</p>",
        "icon_block_state": true,
        "first_num": "2",
        "second_num": "3",
        "color_scheme": "scheme-5",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "product_info2_SA02": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "SHARPEN VS HONE VS STROP",
        "heading_content": "<h2>Three Tools, Three Jobs</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "<h2>KNOW THE DIFFERENCE</h2>",
        "footer_right": "<p><strong>Sharpening</strong> (whetstone) removes metal to create a new edge — do this every 2–4 months. <strong>Honing</strong> (steel rod) straightens a bent edge — do this weekly. <strong>Stropping</strong> (leather) polishes the micro-edge to razor sharpness — do this before each use. All three work together.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_SA03": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "",
        "heading_content": "<h2>The Complete Edge Care System</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "third",
        "footer_left": "<p>Pair with a Xinzuo whetstone for the complete sharpening system. Stone → Rod → Strop. That's the professional sequence that keeps your knives performing at their absolute best.</p>",
        "footer_right": "<p>Australian-owned. 30-day returns. Australian Consumer Law protected.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
