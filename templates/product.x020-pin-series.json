          "blocks": {
            "accordion_row_seo0": {
              "type": "_accordion-row",
              "name": "t:names.accordion_dash_row",
              "settings": {
                "heading": "What steel is in the Retro Series?",
                "content": "<p>The Retro Series uses 10Cr15CoMoV steel with Damascus cladding. The 10Cr15CoMoV core is a Chinese-developed alloy that matches VG10 in performance, with added cobalt for hardness and molybdenum for corrosion resistance. It's hardened to 60 HRC for excellent edge retention.</p>",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_kpwlof": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>The Retro Series uses 10Cr15CoMoV steel with Damascus cladding. The 10Cr15CoMoV core is a Chinese-developed alloy that matches VG10 in performance, with added cobalt for hardness and molybdenum for corrosion resistance. It's hardened to 60 HRC for excellent edge retention.</p>",
