    "product_info_WS01": {
      "type": "product-info",
      "blocks": {
        "icon_WS01a": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-water.svg",
            "content": "<p><strong>Consistent Grit Quality</strong><br/>Manufactured to professional standards for even, predictable results every time you sharpen.</p>"
          }
        },
        "icon_WS01b": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-angle.svg",
            "content": "<p><strong>No Oil Required</strong><br/>Just soak in water for 5–10 minutes and you’re ready to sharpen. No messy honing oil needed.</p>"
          }
        },
        "icon_WS01c": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-stone.svg",
            "content": "<p><strong>Professional Results</strong><br/>The same technique used by Japanese blade makers for centuries. Master it and your knives will never be dull again.</p>"
          }
        },
        "block_WS01a": {
          "type": "block",
          "settings": {
            "header": "Dual-Sided",
            "content": "Two Grits, One Stone",
            "footer": "Coarse side reshapes and removes nicks. Fine side polishes to a razor finish. One stone does the complete job."
          }
        },
        "block_WS01b": {
          "type": "block",
          "settings": {
            "header": "Stable Platform",
            "content": "Non-Slip Base",
            "footer": "Bamboo or silicone base holds the stone locked in place so you can focus on your strokes without slipping."
          }
        },
        "block_WS01c": {
          "type": "block",
          "settings": {
            "header": "Any Knife",
            "content": "Japanese & Western",
            "footer": "15° or 20° — you set the angle. Works with every steel type and blade profile on the market."
          }
        }
      },
      "block_order": [
        "icon_WS01a",
        "icon_WS01b",
        "icon_WS01c",
