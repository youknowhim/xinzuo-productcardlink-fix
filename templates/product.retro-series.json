    "product_info2_7JTdmJ": {
      "type": "product-info2",
      "blocks": {
        "block_GUqr8N": {
          "type": "block",
          "settings": {
            "heading": "The Sharp Core",
            "content": "<p>The 10Cr15CoMoV core is hard enough to hold a razor edge for months, not weeks.</p>"
          }
        },
        "block_C7wDEE": {
          "type": "block",
          "settings": {
            "heading": "The Tough Exterior",
            "content": "<p>The outer stainless layers protect the hard core, preventing chips and adding stain resistance.</p>"
          }
        }
      },
      "block_order": [
        "block_GUqr8N",
        "block_C7wDEE"
      ],
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "THE BEST OF BOTH WORLDS",
        "heading_content": "<h2>The 3-Layer Advantage</h2>",
        "header_type": "left",
        "background_type": "color",
        "block_type": "text",
        "heading_footer": "This is the sweet spot. You get a hard, surgical core that stays sharp, protected by tougher, more flexible steel. It's pro-level performance, without the panic.",
        "image_video": "image",
        "img": "shopify://shop_images/04_4d396ad7-d0c9-4a44-b1d7-c63bca208a2d.png",
        "color_scheme": "scheme-5",
        "footer_state": "hidden",
