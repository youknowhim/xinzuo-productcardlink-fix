      "name": "Product Info",
      "settings": {
        "width": "page",
        "image": "shopify://shop_images/03.jpg",
        "header_type": "left",
        "heading": "",
        "content": "<p>It's all about <strong>smart performance</strong>. The high-carbon core holds a razor edge, while the alloys keep it <strong>tough and chip-free</strong>. </p>",
        "icon_block_state": true,
        "first_num": "2",
