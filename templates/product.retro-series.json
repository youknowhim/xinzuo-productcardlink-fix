    "product_info_mmnV94": {
      "type": "product-info",
      "blocks": {
        "icon_7jadN9": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_3.png",
            "content": "<p><strong>Carbon Hardness</strong><br/>This is the \"stays sharp\" secret. The high-carbon core holds a razor edge for months, not weeks.</p>"
          }
        },
        "icon_mxe7iw": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_4.png",
            "content": "<p><strong>Cobalt Stability</strong><br/>This is the pro-level support crew. It adds serious strength and wear-resistance, keeping the blade stable under heavy use.</p>"
          }
        },
        "icon_NxVM3T": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_1.png",
            "content": "<p><strong>Molybdenum Toughness</strong><br/>This is the \"anti-chip\" ingredient. It adds serious toughness so your blade isn't brittle. All the performance, none of the panic.</p>"
          }
        },
        "icon_GWBWPm": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_2.png",
            "content": "<p><strong>Vanadium Sharpness</strong><br/>This helps create a finer, tighter steel structure. In human terms? It lets the blade take a truly surgical edge and hold it.</p>"
          }
        },
        "block_UJiBwA": {
          "type": "block",
          "settings": {
            "header": "At 60±1 HRC",
            "content": "Pro-Level Edge Retention",
            "footer": "This pro-level hardness means it holds an edge significantly longer than German steel."
          }
        },
        "block_XD86y8": {
          "type": "block",
          "settings": {
            "header": "10Cr15CoMoV Core",
            "content": "Serious Performance",
            "footer": "This high-carbon steel is built to take a surgical edge and just perform."
          }
        },
        "block_pXdtFM": {
          "type": "block",
          "settings": {
            "header": "3-Layer Construction",
            "content": "Tough. Not Brittle.",
            "footer": "The hard core is protected by tougher steel, so it stays sharp without chipping."
          }
        }
      },
      "block_order": [
        "icon_7jadN9",
        "icon_mxe7iw",
