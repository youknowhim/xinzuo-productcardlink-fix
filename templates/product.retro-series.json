    "product_info3_Gx89LP": {
      "type": "product-info3",
      "name": "Product Info3",
      "settings": {
        "width": "page",
        "heading": "The Pro Specs",
        "img": "shopify://shop_images/06_816a66cf-c06c-4041-ae75-7b43640897f6.png",
        "img_text": "Artisan Hammered Finish",
        "info_header1": "Pro-Level Hardness",
        "info_content1": "60 ±1 HRC",
        "info_footer1": "This is pro-level hardness. It holds a razor-sharp edge for months, not weeks. More cooking, less sharpening.",
        "info_header2": "Glides, Doesn't Crush",
        "info_content2": "15° Edge",
        "info_footer2": "A razor-fine 15° edge glides through food with less effort. You get cleaner, smoother cuts every time.",
        "color_scheme": "scheme-5"
      }
    },
    "product_info2_eVwTgB": {
      "type": "product-info2",
      "disabled": true,
      "name": "Product Info2",
      "settings": {
        "width": "full",
        "heading_title": "Handle Design",
        "heading_content": "<h2>Heritage You Can Feel</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "img": "shopify://shop_images/product-pm8s-001.png",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "second",
        "footer_left": "<p>Crafted with North American desert ironwood or refined redwood, seamlessly paired with buffalo horn, the Retro Series handle blends natural strength and timeless beauty. A hammered finish enhances its grip, delivering both artistry and utility.</p>",
        "footer_right": "<h2>Durable</h2><p>Desert ironwood ensures lasting strength.</p><h2>Balanced</h2><p>Buffalo horn adds weight harmony.</p><h2>Distinctive</h2><p>Hammered finish for unique style.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_GjRq8Y": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "",
        "heading_content": "<h2><strong>The One You'll Reach For Every Time</strong></h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "video",
        "video": "shopify://files/videos/pm8s-001.mp4",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "third",
        "footer_left": "<p>3-layer steel blade that stays sharp. Octagonal handle that feels perfect in your hand. Hand-sharpened, vacuum heat-treated, built to last.</p>",
        "footer_right": "<p>This is the knife you'll reach for every single time. 10-year warranty. Gift-ready packaging.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_image1": "shopify://shop_images/Icons.png",
        "additional_content1": "<p>The longer retention of the Retro Series blade ensures chefs <strong>spend less time sharpening and more time cooking</strong>, with reliable sharpness that lasts through demanding, daily professional use.</p>",
        "additional_image2": "shopify://shop_images/Icons_1.png",
        "additional_content2": "<p>The artistic design of Retro Series is revealed in every detail—<strong>from the Damascus finish to wood-and-horn handles</strong>—turning a high-performance knife into a statement of culinary elegance.</p>"
      }
    },
