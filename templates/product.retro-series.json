      }
    },
    "product_info2_8biKrj": {
      "type": "product-info2",
      "disabled": true,
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "PRECISE. DURABLE. REFINED",
        "heading_content": "<h2>Engineered to Stay Razor Sharp</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "Forged with a 15° edge, delivering razor-sharp accuracy, strength, and effortless control for chefs and home cooks.",
        "image_video": "image",
        "img": "shopify://shop_images/07.png",
        "color_scheme": "scheme-5",
        "footer_state": "hidden",
        "footer_type": "first",
        "footer_left": "<h2>Normal Title<br/>Here</h2>",
        "footer_right": "<p>A refined 2.4 mm blade combines sharpness with strength, slicing smoothly while maintaining durability and precision, making every cut efficient, consistent, and highly reliable in the kitchen.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_pVhzYj": {
      "type": "product-info2",
      "blocks": {
        "block_ixcYEh": {
          "type": "block",
          "settings": {
            "heading": "",
            "image": "shopify://shop_images/Icons_2.png",
            "content": "<p><strong>3-Layer Composite Build</strong><br/><br/>This is our modern build. A hard 10Cr15CoMoV core is protected by tougher steel, giving you pro-level sharpness <em>and</em> chip-resistant durability.</p>"
          }
        },
        "block_JUhH4q": {
          "type": "block",
          "settings": {
            "heading": "",
            "image": "shopify://shop_images/Icons_3.png",
            "content": "<p><strong>Vacuum Heat Treatment</strong><br/><br/>This is how we hit 60 HRC hardness *without* making the steel brittle. You get pro-level sharpness, minus the \"oops, it chipped\" panic.</p>"
          }
        },
        "block_RU94Wj": {
          "type": "block",
          "settings": {
            "heading": "",
            "image": "shopify://shop_images/Icons_4.png",
            "content": "<p><strong>Refined by Hand</strong><br/><br/>This is our \"no-shortcuts\" step. We hand-polish and refine every angle to ensure a perfect edge, a balanced feel, and that artisan look.</p>"
          }
        }
      },
      "block_order": [
        "block_ixcYEh",
        "block_JUhH4q",
        "block_RU94Wj"
      ],
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "THE HEAT-TREAT ADVANTAGE",
        "heading_content": "<h2>The Secret is the Temper.</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "icon",
        "heading_footer": "We use a precise Vacuum Heat Treatment to create a pro-level blade. This is how it gets incredibly sharp, but stays tough and chip-resistant.",
        "image_video": "image",
        "img": "shopify://shop_images/product-pm8s-006.png",
        "color_scheme": "scheme-5",
        "footer_state": "hidden",
