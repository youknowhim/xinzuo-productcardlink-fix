    "product_info2_8biKrj": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "CLASSIC DAMASCUS. PROVEN PERFORMANCE.",
        "heading_content": "<h2>The Heritage Collection</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "text",
        "block_position": "below",
        "heading_footer": "The Yi Series is Xinzuo's classic Damascus offering — the same 10Cr15CoMoV core and 67-layer construction found in their premium lines, presented in a timeless rosewood pairing that never goes out of style.",
        "image_video": "image",
        "image_width": 0,
        "image_height": 440,
        "image_width_mobile": 0,
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "<h2>TIMELESS DESIGN</h2>",
        "footer_right": "<p>While other series push towards modern handles or exotic materials, the Yi stays true to the classic formula: genuine Damascus steel, warm rosewood, and a traditional knife shape. Sometimes the original is still the best.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_eVwTgB": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "full",
        "heading_title": "Handle Design",
        "heading_content": "<h2>Natural Rosewood<br/>Classic Warmth</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "block_position": "below",
        "heading_footer": "Rosewood has been the handle material of choice for fine cutlery for centuries. Its natural oils resist moisture, its density provides excellent balance, and its warm grain pattern develops a rich patina with use. Every Yi Series handle is unique.",
        "image_video": "image",
        "image_width": 0,
        "image_height": 440,
        "image_width_mobile": 0,
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "",
        "footer_right": "<h2>Warm</h2><p>Natural rosewood radiates warmth in hand and on display.</p><h2>Balanced</h2><p>Dense hardwood perfectly counterbalances the Damascus blade.</p><h2>Timeless</h2><p>A classic material that develops character with every use.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info2_GjRq8Y": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "",
        "heading_content": "<h2>Why Choose the<br/>Yi Series</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "block_position": "below",
        "heading_footer": "",
        "image_video": "image",
        "image_width": 0,
        "image_height": 440,
        "image_width_mobile": 0,
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "third",
        "footer_left": "<p>The Yi Series delivers the complete Damascus experience at a considered price point. With 10 knife types covering every essential task, it's a focused collection that doesn't waste space on novelty blades — every knife earns its place.</p>",
        "footer_right": "<p>If you want the beauty and performance of genuine 67-layer Damascus without stepping into ultra-premium pricing, the Yi Series delivers. Classic rosewood handles provide warmth and character that synthetic materials can't replicate.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
