        "icon_GWBWPm": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_2.png",
            "content": "<p><strong>Vanadium Sharpness</strong><br/>This helps create a finer, tighter steel structure. In human terms? It lets the blade take a truly surgical edge and hold it.</p>"
