        "icon_mxe7iw": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square.png",
            "content": "<p><strong>Chromium Protection</strong><br/>This is what fights off rust and stains. It keeps your knife looking clean and sharp, even in a busy, wet kitchen.</p>"
