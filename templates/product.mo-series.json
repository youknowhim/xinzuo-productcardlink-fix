        "additional_content1": "",
        "additional_content2": ""
      }
    },
    "product_info6_M4zfaM": {
      "type": "product-info6",
      "name": "Product Info6",
      "settings": {
        "width": "page",
        "heading_title": "Knife Design",
        "heading_content": "<h2>Artistry in</h2><h2>Detail</h2>",
        "header_type": "center",
        "heading_footer": "",
        "left_img": "shopify://shop_images/product-x06-008.png",
        "left_title": "<h2>Artful</h2>",
        "left_content": "<p>The Mo Series blade features an acid-etched, battle-forged Damascus pattern with a black titanium water-wave stonewash, delivering striking visual artistry, reduced food adhesion, and durable, performance-driven elegance in every cut.</p>",
        "right_img": "shopify://shop_images/product-x06-007.png",
        "right_title": "<h2>Ergonomic</h2>",
        "right_content": "<p>The Mo Series handle blends burnt white oak with bold red G10, delivering a refined, durable aesthetic that is ergonomic, moisture-resistant, exceptionally comfortable in extended use, stable under pressure, and a superior upgrade over plain wooden handles.</p>",
        "color_scheme": "scheme-5",
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "product_info2_GjRq8Y": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "",
        "heading_content": "<h2>Built</h2><h2>for Brilliance</h2>",
        "header_type": "center",
        "background_type": "none",
        "block_type": "text",
        "block_position": "below",
        "heading_footer": "",
        "image_video": "video",
        "video": "shopify://files/videos/X06-001-without-cow.mp4",
        "image_width": 0,
        "image_height": 440,
        "image_width_mobile": 0,
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "third",
        "footer_left": "<p>Mo Series embodies advanced craftsmanship, forged with 67-layer Damascus and a VG10-equivalent core. It delivers razor precision, long-lasting edge retention, and strength that endures through demanding professional use.</p>",
        "footer_right": "<p>From its black titanium Damascus finish to the burnt oak and red G10 handle, every Mo Series detail unites toughness with elegance—built for perfection, slice after slice.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": true,
        "additional_image1": "shopify://shop_images/Icons_1_9cb45a40-18f4-4ddb-aac9-66c8772d049e.png",
        "additional_content1": "<p>The VG10-equivalent core wrapped in 66 Damascus layers gives Mo Series its <strong>lasting sharpness, strength, and resilience</strong>—keeping chefs focused on cooking, not constant sharpening.</p>",
        "additional_image2": "shopify://shop_images/Icons_2_ada91f16-e94d-41b1-bbf3-08db7688a8fa.png",
        "additional_content2": "<p>A water-wave Damascus pattern, acid-etched and stonewashed in black titanium, gives Mo Series its bold identity—<strong>striking, anti-stick, and elevated to near perfection</strong> in both design and performance.</p>"
      }
    },
