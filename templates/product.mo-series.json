      "blocks": {
        "icon_7jadN9": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_3.png",
            "content": "<p><strong>Carbon Hardness<br/></strong>This is the \"stays sharp\" secret. The high-carbon core holds a razor edge for months, not weeks.</p>"
