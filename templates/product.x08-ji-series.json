    "product_info_mmnV94": {
      "type": "product-info",
      "blocks": {
        "icon_7jadN9": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square.png",
            "content": "<p><strong>High-Carbon Core</strong><br/>Carbon content delivers exceptional hardness at the cutting edge, allowing the blade to hold a keen edge through extended use.</p>"
          }
        },
        "icon_mxe7iw": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_1.png",
            "content": "<p><strong>18% Chromium</strong><br/>Industry-leading corrosion resistance — significantly higher than VG10-class steels. Ideal for cooks who work with acidic ingredients daily.</p>"
          }
        },
        "icon_NxVM3T": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/Square_2.png",
            "content": "<p><strong>67-Layer Damascus</strong><br/>Protective cladding surrounds the hard core steel, adding toughness, corrosion resistance, and the iconic Damascus wave pattern.</p>"
          }
        },
        "block_UJiBwA": {
          "type": "block",
          "settings": {
            "header": "59-61 HRC",
            "content": "Premium Hardness",
            "footer": "Professional-grade hardness that balances edge retention with ease of maintenance — sharp enough for precision work, forgiving enough for daily use."
          }
        },
        "block_XD86y8": {
          "type": "block",
          "settings": {
            "header": "12Cr18MoV",
            "content": "Proprietary Steel",
            "footer": "Xinzuo's own steel composition — not available from any other brand. Higher chromium than standard Damascus steels for superior corrosion resistance."
          }
        },
        "block_pXdtFM": {
          "type": "block",
          "settings": {
            "header": "Ebony Wood",
            "content": "Premium Handle",
            "footer": "One of the world's most prized handle woods — dense, naturally water-resistant, and finished to a deep black polish that contrasts beautifully with Damascus steel."
          }
        }
      },
      "block_order": [
        "icon_7jadN9",
