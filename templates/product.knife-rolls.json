    "product_info_KR01": {
      "type": "product-info",
      "blocks": {
        "icon_KR01a": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-roll.svg",
            "content": "<p><strong>Premium Materials</strong><br/>Waxed canvas and genuine full-grain leather that develops a rich patina with every use.</p>"
          }
        },
        "icon_KR01b": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-lock.svg",
            "content": "<p><strong>Individual Pockets</strong><br/>Each knife sits in its own slot. No blade-on-blade contact, no edge damage during transport.</p>"
          }
        },
        "icon_KR01c": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-travel.svg",
            "content": "<p><strong>Compact When Rolled</strong><br/>Rolls tight and fits easily in a backpack, messenger bag, or carry-on luggage.</p>"
