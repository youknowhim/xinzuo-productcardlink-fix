        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "<h2>THE TRANSPORT PROBLEM</h2>",
        "footer_right": "<p>Throwing knives loose into a bag — even wrapped in a towel — leads to chipped tips, dulled edges, and scratched blades. A proper knife roll holds each knife individually, padded and separated, so they arrive at your destination in the same condition they left.</p>",
        "padding_top": 80,
