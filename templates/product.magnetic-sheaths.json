      "name": "Product Info",
      "settings": {
        "width": "page",
        "header_type": "left",
        "heading": "<h2>Premium Blade Protection</h2>",
        "content": "<p>Drawer storage is the number one cause of dulled and chipped edges. A magnetic sheath wraps your blade in premium walnut, snapping securely shut to protect the cutting edge — whether in a drawer, a knife roll, or on the counter.</p>",
        "icon_block_state": true,
        "first_num": "3",
        "second_num": "3",
        "color_scheme": "scheme-5",
        "padding_top": 80,
