    "product_info2_MH02": {
      "type": "product-info2",
      "name": "Product Info2",
      "settings": {
        "width": "page",
        "heading_title": "THE JAPANESE SAYA TRADITION",
        "heading_content": "<h2>A Blade Deserves a Home</h2>",
        "header_type": "left",
        "background_type": "none",
        "block_type": "text",
        "heading_footer": "",
        "image_video": "image",
        "color_scheme": "scheme-5",
        "footer_state": "visible",
        "footer_type": "first",
        "footer_left": "<h2>THE CRAFT</h2>",
        "footer_right": "<p>In Japanese knife-making, the 'saya' (wooden sheath) is as much a part of the knife as the blade itself. It protects the edge, prevents accidents, and shows respect for the tool. Our magnetic sheaths honour this tradition with modern engineering.</p>",
        "padding_top": 80,
        "padding_bottom": 80,
        "additional_footer": false,
