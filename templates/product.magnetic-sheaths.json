    "product_info_MH01": {
      "type": "product-info",
      "blocks": {
        "icon_MH01_1": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-magnet-lock.svg",
            "content": "<p><strong>Magnetic Locking System</strong><br/>Internal magnets grip the spine of the blade. No pins, clips, or straps needed. Slides in, clicks shut.</p>"
          }
        },
        "icon_MH01_2": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-wood.svg",
            "content": "<p><strong>American Walnut</strong><br/>Each sheath is crafted from a single piece of spliced walnut for durability and a rich, natural grain.</p>"
          }
        },
        "icon_MH01_3": {
          "type": "icon",
          "settings": {
            "image": "shopify://shop_images/icon-lock.svg",
            "content": "<p><strong>Reinforced Base</strong><br/>Sandblasted 430 stainless steel plate at the base prevents tip pierce-through for complete protection.</p>"
          }
        },
        "block_MH01_1": {
          "type": "block",
          "settings": {
            "header": "Drawer Safe",
            "content": "Protect Your Edge",
            "footer": "Store your knife in a drawer without worrying about the blade touching other utensils. The sheath wraps and shields the entire cutting edge."
          }
        },
        "block_MH01_2": {
          "type": "block",
          "settings": {
            "header": "Travel Ready",
            "content": "Roll or Bag",
            "footer": "Pair with a knife roll for safe transport. The magnet keeps the blade locked even during movement."
          }
        },
        "block_MH01_3": {
          "type": "block",
          "settings": {
            "header": "Series-Matched",
            "content": "Precision Fit",
            "footer": "Each sheath is sized for specific Xinzuo series — check compatibility to find your fit."
          }
        }
      },
