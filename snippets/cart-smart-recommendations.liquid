{%- comment -%}
  Cart Smart Recommendations
  Determines which products to recommend based on cart contents.
  
  Logic:
  - Priority products (Knife Holder, Whetstone) ALWAYS appear first in ALL cases
  - 1 knife: Priority + Sheath (from metafield) + 3 knives from same series
  - 2 knives: Priority + 4 knives from same series
  - 3+ knives or default: Priority + Admin-configured products
  
  @param {string} context - 'drawer' or 'page'
{%- endcomment -%}

{%- liquid
  # Initialize variables
  assign knife_count = 0
  assign knives_in_cart = ''
  assign cart_product_ids = ''
  assign cart_product_types = ''
  assign primary_knife = null
  assign primary_series_code = ''
  assign sheath_product = null
  assign has_sheath = false
  
  # Count knives and collect data
  for item in cart.items
    # Build list of product IDs in cart (for exclusion)
    if cart_product_ids == ''
      assign cart_product_ids = item.product.id | append: ''
    else
      assign cart_product_ids = cart_product_ids | append: ',' | append: item.product.id
    endif
    
    # Build list of product types in cart (for variety)
    assign item_type = item.product.type | downcase
    if cart_product_types == ''
      assign cart_product_types = item_type
    else
      unless cart_product_types contains item_type
        assign cart_product_types = cart_product_types | append: ',' | append: item_type
      endunless
    endif
    
    # Check if item is a knife using metafield
    if item.product.metafields.custom.isknife == true
      assign knife_count = knife_count | plus: item.quantity
      
      # Store first knife as primary (most recently added is first in cart.items)
      if primary_knife == null
        assign primary_knife = item.product
        
        # Extract series code from product title
        # Format: "8" Chef Knife - Supreme Series (X02)"
        assign title_parts = item.product.title | split: '('
        if title_parts.size > 1
          assign code_part = title_parts | last | split: ')' | first
          assign primary_series_code = code_part | strip
        endif
        
        # Check for sheath metafield
        if item.product.metafields.custom.sheath != blank
          assign sheath_product = item.product.metafields.custom.sheath.value
          assign has_sheath = true
        endif
      endif
      
      # Collect knife IDs for reference
      if knives_in_cart == ''
        assign knives_in_cart = item.product.id | append: ''
      else
        assign knives_in_cart = knives_in_cart | append: ',' | append: item.product.id
      endif
    endif
  endfor
  
  # Determine scenario and heading
  assign scenario = 'default'
  assign heading = settings.cart_rec_default_heading | default: 'You Might Also Like'
  assign recommended_products = null
  
  if knife_count == 1
    assign scenario = 'one_knife'
    assign heading = settings.cart_rec_1_knife_heading | default: 'Knives That Go Best With This'
  elsif knife_count == 2
    assign scenario = 'two_knives'
    assign heading = settings.cart_rec_2_knives_heading | default: 'Knives That Go Best With These'
  elsif knife_count >= 3
    assign scenario = 'three_plus'
    assign heading = settings.cart_rec_default_heading | default: 'You Might Also Like'
  endif
  
  # Build priority products list (always shown first, excluding items already in cart)
  assign priority_products_filtered = ''
  assign priority_count = 0
  for priority_product in settings.cart_rec_priority_products
    assign priority_id_str = priority_product.id | append: ''
    unless cart_product_ids contains priority_id_str
      if priority_products_filtered == ''
        assign priority_products_filtered = priority_id_str
      else
        assign priority_products_filtered = priority_products_filtered | append: ',' | append: priority_id_str
      endif
      assign priority_count = priority_count | plus: 1
    endunless
  endfor
-%}

{%- comment -%} Debug info (remove in production) {%- endcomment -%}
<!-- Cart Smart Recommendations Debug:
  Scenario: {{ scenario }}
  Knife Count: {{ knife_count }}
  Primary Series Code: {{ primary_series_code }}
  Has Sheath: {{ has_sheath }}
  Cart Product IDs: {{ cart_product_ids }}
  Priority Products: {{ priority_products_filtered }}
-->

{%- if scenario == 'one_knife' or scenario == 'two_knives' -%}
  {%- comment -%} 
    Smart recommendations for 1-2 knives
    Priority products first, then sheath (if 1 knife), then knives from same series
  {%- endcomment -%}
  
  {%- liquid
    # Determine how many knife recommendations we need
    # 1 knife: priority + sheath + 3 knives
    # 2 knives: priority + 4 knives
    if scenario == 'one_knife'
      assign knives_needed = 3
    else
      assign knives_needed = 4
    endif
    
    # We'll collect recommendations from all knives collection
    # and filter by series code
    assign smart_recommendations = ''
    assign rec_count = 0
  -%}
  
  {%- comment -%} Get products from knives collection that match the series {%- endcomment -%}
  {%- assign knives_collection = collections['knives'] -%}
  
  {%- if knives_collection != blank and primary_series_code != '' -%}
    {%- for product in knives_collection.products -%}
      {%- liquid
        # Skip if already in cart
        assign product_id_str = product.id | append: ''
        assign is_in_cart = false
        if cart_product_ids contains product_id_str
          assign is_in_cart = true
        endif
        
        # Skip if same product type as primary knife (for variety)
        assign product_type_lower = product.type | downcase
        assign primary_type_lower = primary_knife.type | downcase
        assign same_type = false
        if product_type_lower == primary_type_lower
          assign same_type = true
        endif
        
        # Check if product matches the series code
        assign matches_series = false
        if product.title contains primary_series_code
          assign matches_series = true
        endif
        
        # Add to recommendations if matches criteria
        if matches_series and is_in_cart == false and rec_count < knives_needed
          if smart_recommendations == ''
            assign smart_recommendations = product.id | append: ''
          else
            assign smart_recommendations = smart_recommendations | append: ',' | append: product.id
          endif
          assign rec_count = rec_count | plus: 1
        endif
      -%}
    {%- endfor -%}
  {%- endif -%}
  
  {%- comment -%} If not enough recommendations from same series, try similar price tier {%- endcomment -%}
  {%- if rec_count < knives_needed and knives_collection != blank -%}
    {%- liquid
      assign primary_price = primary_knife.price
      assign price_low = primary_price | times: 0.7
      assign price_high = primary_price | times: 1.3
    -%}
    
    {%- for product in knives_collection.products -%}
      {%- liquid
        # Skip if already in cart or already recommended
        assign product_id_str = product.id | append: ''
        assign is_in_cart = false
        assign already_recommended = false
        
        if cart_product_ids contains product_id_str
          assign is_in_cart = true
        endif
        
        if smart_recommendations contains product_id_str
          assign already_recommended = true
        endif
        
        # Check price range
        assign in_price_range = false
        if product.price >= price_low and product.price <= price_high
          assign in_price_range = true
        endif
        
        # Add to recommendations if matches criteria
        if in_price_range and is_in_cart == false and already_recommended == false and rec_count < knives_needed
          if smart_recommendations == ''
            assign smart_recommendations = product.id | append: ''
          else
            assign smart_recommendations = smart_recommendations | append: ',' | append: product.id
          endif
          assign rec_count = rec_count | plus: 1
        endif
      -%}
    {%- endfor -%}
  {%- endif -%}
  
  {%- comment -%} Build the final product list: Priority + Sheath (if 1 knife) + Smart recommendations {%- endcomment -%}
  {%- capture final_products_capture -%}
    {%- comment -%} 1. Priority products first (Knife Holder, Whetstone, etc.) {%- endcomment -%}
    {%- if priority_products_filtered != '' -%}
      {{ priority_products_filtered }},
    {%- endif -%}
    {%- comment -%} 2. Sheath if 1 knife and available (but NOT if already in cart) {%- endcomment -%}
    {%- if scenario == 'one_knife' and has_sheath and sheath_product != blank -%}
      {%- assign sheath_id_check = sheath_product.id | append: '' -%}
      {%- unless cart_product_ids contains sheath_id_check -%}
        {{ sheath_product.id }},
      {%- endunless -%}
    {%- endif -%}
    {%- comment -%} 3. Smart knife recommendations {%- endcomment -%}
    {{ smart_recommendations }}
  {%- endcapture -%}
  
  {%- assign final_product_ids = final_products_capture | strip | split: ',' -%}
  
  {%- comment -%} Render the recommendations {%- endcomment -%}
  {%- if final_product_ids.size > 0 -%}
    <div class="cart-recommended-products cart-recommended-products--{{ context }}" data-cart-recommended-slider>
      <div class="cart-recommended-products__header">
        <h2 class="cart-recommended-products__heading">{{ heading }}</h2>
        {%- if final_product_ids.size > 1 -%}
          <div class="cart-recommended-products__counter">
            <span class="cart-recommended-products__counter-current">1</span>/<span class="cart-recommended-products__counter-total">{{ final_product_ids.size }}</span>
          </div>
        {%- endif -%}
      </div>
      
      <div class="cart-recommended-products__swiper swiper">
        {%- if final_product_ids.size > 1 -%}
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--prev" 
            aria-label="Previous products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M15 19.5L7.5 12L15 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--next" 
            aria-label="Next products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M9 4.5L16.5 12L9 19.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
        <div class="swiper-wrapper">
          {%- for product_id in final_product_ids -%}
            {%- assign product_id_clean = product_id | strip -%}
            {%- if product_id_clean != '' -%}
              {%- comment -%} Try to find product from various sources {%- endcomment -%}
              {%- assign rec_product = null -%}
              
              {%- comment -%} Check priority products first {%- endcomment -%}
              {%- for p in settings.cart_rec_priority_products -%}
                {%- assign p_id_str = p.id | append: '' -%}
                {%- if p_id_str == product_id_clean -%}
                  {%- assign rec_product = p -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              
              {%- comment -%} Check sheath product {%- endcomment -%}
              {%- if rec_product == blank and has_sheath and sheath_product != blank -%}
                {%- assign sheath_id_str = sheath_product.id | append: '' -%}
                {%- if sheath_id_str == product_id_clean -%}
                  {%- assign rec_product = sheath_product -%}
                {%- endif -%}
              {%- endif -%}
              
              {%- comment -%} Try knives collection {%- endcomment -%}
              {%- if rec_product == blank and knives_collection != blank -%}
                {%- for p in knives_collection.products -%}
                  {%- assign p_id_str = p.id | append: '' -%}
                  {%- if p_id_str == product_id_clean -%}
                    {%- assign rec_product = p -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              
              {%- comment -%} Fallback to all_products {%- endcomment -%}
              {%- if rec_product == blank -%}
                {%- assign rec_product = all_products[product_id_clean] -%}
              {%- endif -%}
              
              {%- if rec_product != blank -%}
                {%- assign variant_to_use = rec_product.selected_or_first_available_variant -%}
                {%- liquid
                  # Prefer metafield main_image (black-bg canonical) when present,
                  # mirroring xz-product-card.liquid + cart-products.liquid resolution.
                  assign rec_image = rec_product.featured_image
                  assign rec_meta_image = rec_product.metafields.custom.main_image
                  if rec_meta_image != blank
                    if rec_meta_image.image
                      assign rec_meta_image = rec_meta_image.image
                    endif
                    assign rec_image = rec_meta_image
                  endif
                -%}
                <div class="swiper-slide">
                  <div class="cart-recommended-product">
                    <a href="{{ rec_product.url }}" class="cart-recommended-product__image-link">
                      <div class="cart-recommended-product__image">
                        {%- if rec_image -%}
                          {{
                            rec_image
                            | image_url: width: 200
                            | image_tag:
                              loading: 'lazy',
                              width: rec_image.width,
                              height: rec_image.height,
                              alt: rec_product.title | escape
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                        {%- endif -%}
                      </div>
                    </a>
                    <div class="cart-recommended-product__info">
                      <a href="{{ rec_product.url }}" class="cart-recommended-product__title-link">
                        <h3 class="cart-recommended-product__title">{{ rec_product.title }}</h3>
                      </a>
                      <div class="cart-recommended-product__price">
                        {%- if rec_product.compare_at_price > rec_product.price -%}
                          <span class="cart-recommended-product__price--sale">{{ rec_product.price | money }}</span>
                          <span class="cart-recommended-product__price--compare">{{ rec_product.compare_at_price | money }}</span>
                        {%- else -%}
                          <span class="cart-recommended-product__price--regular">{{ rec_product.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    <button
                      type="button"
                      class="cart-recommended-product__add-btn"
                      data-product-id="{{ rec_product.id }}"
                      data-variant-id="{{ variant_to_use.id }}"
                      data-product-title="{{ rec_product.title | escape }}"
                      {% unless variant_to_use.available %}disabled{% endunless %}
                      aria-label="Add {{ rec_product.title }} to cart"
                    >
                      <span class="cart-recommended-product__add-btn-text">Add</span>
                    </button>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- else -%}
    {%- comment -%} Fallback to default products if no smart recommendations found {%- endcomment -%}
    {%- if settings.cart_recommended_products != blank -%}
      {% render 'cart-recommended-products', 
        recommended_products: settings.cart_recommended_products,
        heading: heading,
        context: context
      %}
    {%- endif -%}
  {%- endif -%}

{%- elsif scenario == 'three_plus' or scenario == 'default' -%}
  {%- comment -%} 
    3+ knives or default: Priority products + admin-configured products 
    We need to merge priority products with default products
  {%- endcomment -%}
  
  {%- capture merged_products_capture -%}
    {%- if priority_products_filtered != '' -%}
      {{ priority_products_filtered }},
    {%- endif -%}
    {%- for default_product in settings.cart_recommended_products -%}
      {%- assign default_id_str = default_product.id | append: '' -%}
      {%- comment -%} Skip if already in cart or in priority products {%- endcomment -%}
      {%- unless cart_product_ids contains default_id_str or priority_products_filtered contains default_id_str -%}
        {{ default_id_str }},
      {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}
  
  {%- assign merged_product_ids = merged_products_capture | strip | split: ',' -%}
  
  {%- if merged_product_ids.size > 0 -%}
    <div class="cart-recommended-products cart-recommended-products--{{ context }}" data-cart-recommended-slider>
      <div class="cart-recommended-products__header">
        <h2 class="cart-recommended-products__heading">{{ heading }}</h2>
        {%- if merged_product_ids.size > 1 -%}
          <div class="cart-recommended-products__counter">
            <span class="cart-recommended-products__counter-current">1</span>/<span class="cart-recommended-products__counter-total">{{ merged_product_ids.size }}</span>
          </div>
        {%- endif -%}
      </div>
      
      <div class="cart-recommended-products__swiper swiper">
        {%- if merged_product_ids.size > 1 -%}
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--prev" 
            aria-label="Previous products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M15 19.5L7.5 12L15 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--next" 
            aria-label="Next products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M9 4.5L16.5 12L9 19.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
        <div class="swiper-wrapper">
          {%- for product_id in merged_product_ids -%}
            {%- assign product_id_clean = product_id | strip -%}
            {%- if product_id_clean != '' -%}
              {%- assign rec_product = null -%}
              
              {%- comment -%} Check priority products {%- endcomment -%}
              {%- for p in settings.cart_rec_priority_products -%}
                {%- assign p_id_str = p.id | append: '' -%}
                {%- if p_id_str == product_id_clean -%}
                  {%- assign rec_product = p -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              
              {%- comment -%} Check default products {%- endcomment -%}
              {%- if rec_product == blank -%}
                {%- for p in settings.cart_recommended_products -%}
                  {%- assign p_id_str = p.id | append: '' -%}
                  {%- if p_id_str == product_id_clean -%}
                    {%- assign rec_product = p -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              
              {%- if rec_product != blank -%}
                {%- assign variant_to_use = rec_product.selected_or_first_available_variant -%}
                {%- liquid
                  # Prefer metafield main_image (black-bg canonical) when present,
                  # mirroring xz-product-card.liquid + cart-products.liquid resolution.
                  assign rec_image = rec_product.featured_image
                  assign rec_meta_image = rec_product.metafields.custom.main_image
                  if rec_meta_image != blank
                    if rec_meta_image.image
                      assign rec_meta_image = rec_meta_image.image
                    endif
                    assign rec_image = rec_meta_image
                  endif
                -%}
                <div class="swiper-slide">
                  <div class="cart-recommended-product">
                    <a href="{{ rec_product.url }}" class="cart-recommended-product__image-link">
                      <div class="cart-recommended-product__image">
                        {%- if rec_image -%}
                          {{
                            rec_image
                            | image_url: width: 200
                            | image_tag:
                              loading: 'lazy',
                              width: rec_image.width,
                              height: rec_image.height,
                              alt: rec_product.title | escape
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                        {%- endif -%}
                      </div>
                    </a>
                    <div class="cart-recommended-product__info">
                      <a href="{{ rec_product.url }}" class="cart-recommended-product__title-link">
                        <h3 class="cart-recommended-product__title">{{ rec_product.title }}</h3>
                      </a>
                      <div class="cart-recommended-product__price">
                        {%- if rec_product.compare_at_price > rec_product.price -%}
                          <span class="cart-recommended-product__price--sale">{{ rec_product.price | money }}</span>
                          <span class="cart-recommended-product__price--compare">{{ rec_product.compare_at_price | money }}</span>
                        {%- else -%}
                          <span class="cart-recommended-product__price--regular">{{ rec_product.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    <button
                      type="button"
                      class="cart-recommended-product__add-btn"
                      data-product-id="{{ rec_product.id }}"
                      data-variant-id="{{ variant_to_use.id }}"
                      data-product-title="{{ rec_product.title | escape }}"
                      {% unless variant_to_use.available %}disabled{% endunless %}
                      aria-label="Add {{ rec_product.title }} to cart"
                    >
                      <span class="cart-recommended-product__add-btn-text">Add</span>
                    </button>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

{%- else -%}
  {%- comment -%} No knives in cart: Priority products + admin-configured products {%- endcomment -%}
  
  {%- capture merged_products_capture -%}
    {%- if priority_products_filtered != '' -%}
      {{ priority_products_filtered }},
    {%- endif -%}
    {%- for default_product in settings.cart_recommended_products -%}
      {%- assign default_id_str = default_product.id | append: '' -%}
      {%- unless cart_product_ids contains default_id_str or priority_products_filtered contains default_id_str -%}
        {{ default_id_str }},
      {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}
  
  {%- assign merged_product_ids = merged_products_capture | strip | split: ',' -%}
  
  {%- if merged_product_ids.size > 0 -%}
    <div class="cart-recommended-products cart-recommended-products--{{ context }}" data-cart-recommended-slider>
      <div class="cart-recommended-products__header">
        <h2 class="cart-recommended-products__heading">{{ heading }}</h2>
        {%- if merged_product_ids.size > 1 -%}
          <div class="cart-recommended-products__counter">
            <span class="cart-recommended-products__counter-current">1</span>/<span class="cart-recommended-products__counter-total">{{ merged_product_ids.size }}</span>
          </div>
        {%- endif -%}
      </div>
      
      <div class="cart-recommended-products__swiper swiper">
        {%- if merged_product_ids.size > 1 -%}
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--prev" 
            aria-label="Previous products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M15 19.5L7.5 12L15 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button 
            class="cart-recommended-products__button cart-recommended-products__button--next" 
            aria-label="Next products"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M9 4.5L16.5 12L9 19.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
        <div class="swiper-wrapper">
          {%- for product_id in merged_product_ids -%}
            {%- assign product_id_clean = product_id | strip -%}
            {%- if product_id_clean != '' -%}
              {%- assign rec_product = null -%}
              
              {%- comment -%} Check priority products {%- endcomment -%}
              {%- for p in settings.cart_rec_priority_products -%}
                {%- assign p_id_str = p.id | append: '' -%}
                {%- if p_id_str == product_id_clean -%}
                  {%- assign rec_product = p -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              
              {%- comment -%} Check default products {%- endcomment -%}
              {%- if rec_product == blank -%}
                {%- for p in settings.cart_recommended_products -%}
                  {%- assign p_id_str = p.id | append: '' -%}
                  {%- if p_id_str == product_id_clean -%}
                    {%- assign rec_product = p -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              
              {%- if rec_product != blank -%}
                {%- assign variant_to_use = rec_product.selected_or_first_available_variant -%}
                {%- liquid
                  # Prefer metafield main_image (black-bg canonical) when present,
                  # mirroring xz-product-card.liquid + cart-products.liquid resolution.
                  assign rec_image = rec_product.featured_image
                  assign rec_meta_image = rec_product.metafields.custom.main_image
                  if rec_meta_image != blank
                    if rec_meta_image.image
                      assign rec_meta_image = rec_meta_image.image
                    endif
                    assign rec_image = rec_meta_image
                  endif
                -%}
                <div class="swiper-slide">
                  <div class="cart-recommended-product">
                    <a href="{{ rec_product.url }}" class="cart-recommended-product__image-link">
                      <div class="cart-recommended-product__image">
                        {%- if rec_image -%}
                          {{
                            rec_image
                            | image_url: width: 200
                            | image_tag:
                              loading: 'lazy',
                              width: rec_image.width,
                              height: rec_image.height,
                              alt: rec_product.title | escape
                          }}
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                        {%- endif -%}
                      </div>
                    </a>
                    <div class="cart-recommended-product__info">
                      <a href="{{ rec_product.url }}" class="cart-recommended-product__title-link">
                        <h3 class="cart-recommended-product__title">{{ rec_product.title }}</h3>
                      </a>
                      <div class="cart-recommended-product__price">
                        {%- if rec_product.compare_at_price > rec_product.price -%}
                          <span class="cart-recommended-product__price--sale">{{ rec_product.price | money }}</span>
                          <span class="cart-recommended-product__price--compare">{{ rec_product.compare_at_price | money }}</span>
                        {%- else -%}
                          <span class="cart-recommended-product__price--regular">{{ rec_product.price | money }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    <button
                      type="button"
                      class="cart-recommended-product__add-btn"
                      data-product-id="{{ rec_product.id }}"
                      data-variant-id="{{ variant_to_use.id }}"
                      data-product-title="{{ rec_product.title | escape }}"
                      {% unless variant_to_use.available %}disabled{% endunless %}
                      aria-label="Add {{ rec_product.title }} to cart"
                    >
                      <span class="cart-recommended-product__add-btn-text">Add</span>
                    </button>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}
