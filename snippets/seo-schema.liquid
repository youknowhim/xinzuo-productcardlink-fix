    "contentUrl": {{ "https://www.youtube.com/watch?v=" | append: media.external_id | json }},
  {%- endif -%}
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
  }
}
</script>
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
