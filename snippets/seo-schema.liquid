{%- comment -%} 
  FAQPage Schema - Add common FAQs for product pages
  These are brand-level FAQs that appear across product pages
{%- endcomment -%}
{%- comment -%} Related Products Schema for internal linking signals {%- endcomment -%}
{%- if request.page_type == 'product' and product and product.collections.first -%}
  {%- assign has_related = false -%}
  {%- for p in product.collections.first.products limit: 6 -%}
    {%- if p.id != product.id -%}
      {%- assign has_related = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if has_related -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Related Products",
  "description": {{ "Products related to " | append: product.title | json }},
  "itemListElement": [
    {%- assign position = 0 -%}
    {%- for related in product.collections.first.products limit: 6 -%}
      {%- if related.id != product.id and position < 5 -%}
        {%- assign position = position | plus: 1 -%}
        {%- if position > 1 -%},{%- endif -%}
      {
        "@type": "ListItem",
        "position": {{ position }},
        "item": {
          "@type": "Product",
          "name": {{ related.title | json }},
          "url": {{ related.url | prepend: shop.url | json }},
          {%- if related.featured_image -%}
            "image": {{ related.featured_image | image_url: width: 600 | prepend: "https:" | json }},
          {%- endif -%}
          "offers": {
            "@type": "Offer",
            "price": {{ related.price | divided_by: 100.0 | json }},
            "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
            "availability": "https://schema.org/{% if related.available %}InStock{% else %}OutOfStock{% endif %}"
          }
        }
      }
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
  {%- endif -%}
{%- endif -%}

{%- if request.page_type == 'product' and product -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What makes Xinzuo knives stand apart from other kitchen knife brands?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Xinzuo knives combine premium steel, precision forging, and ergonomic design. Each blade is carefully crafted to deliver durability, sharpness, and balance, creating a superior cutting experience for both chefs and home cooks."
      }
    },
    {
      "@type": "Question",
      "name": "Are Xinzuo knives designed for professional chefs as well as home kitchens?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, Xinzuo knives are designed for both professional chefs and home cooks. Our range includes entry-level options for beginners and premium Damascus steel knives for professionals who demand the highest quality."
      }
    },
    {
      "@type": "Question",
      "name": "How should I properly care for my Xinzuo knife collection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hand wash your Xinzuo knives with mild soap and dry immediately. Avoid dishwashers, as they can damage the blade. Store in a knife block or magnetic strip. Sharpen regularly with a whetstone or honing rod to maintain optimal edge retention."
      }
    },
    {
      "@type": "Question",
      "name": "Do Xinzuo products include a warranty, and what does it cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all Xinzuo knives come with a lifetime warranty covering manufacturing defects. This includes blade defects, handle issues, and craftsmanship problems. Normal wear and damage from misuse are not covered."
      }
    },
    {
      "@type": "Question",
      "name": "How long does delivery of Xinzuo knives usually take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer fast shipping within Australia. Standard delivery takes 2-7 business days depending on your location. Express shipping options are available for faster delivery. Free shipping is available on orders over $100."
      }
    }
  ]
}
</script>
{%- endif -%}

