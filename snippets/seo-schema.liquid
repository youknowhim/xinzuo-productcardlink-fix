{%- comment -%} Collection Page Schema - Enhanced with Keywords {%- endcomment -%}
{%- if request.page_type == 'collection' and collection -%}
{%- liquid
  # Generate SEO keywords based on collection
  assign seo_keywords = 'kitchen knives, chef knives, Damascus steel, premium knives'
  assign seo_description = 'Shop ' | append: collection.title | append: ' at ' | append: shop.name | append: '. Premium quality kitchen knives and accessories with free shipping over $100.'
  
  case collection.handle
    when 'all-products'
      assign seo_keywords = 'kitchen knives Australia, Damascus steel knives, chef knives, santoku knives, knife accessories, premium knives, hand-forged knives'
      assign seo_description = 'Shop the complete range of premium kitchen knives and accessories. Hand-forged Damascus steel blades with lifetime warranty and free Australian shipping over $100.'
    when 'knives'
      assign seo_keywords = 'kitchen knives, chef knives, Damascus steel, Japanese knives, professional knives, hand-forged knives, santoku, cleaver'
      assign seo_description = 'Professional-grade kitchen knives crafted from premium Damascus steel. Hand-forged for exceptional sharpness and edge retention.'
    when 'chopping-boards'
      assign seo_keywords = 'chopping boards, cutting boards, wooden boards, kitchen boards, butcher blocks, end grain boards'
      assign seo_description = 'Premium wooden chopping boards designed for professional kitchens. Durable, knife-friendly surfaces.'
    when 'knife-holders'
      assign seo_keywords = 'knife holders, magnetic knife holder, knife block, knife storage, knife rack, magnetic knife strip'
      assign seo_description = 'Magnetic knife holders and blocks for safe knife storage. Protect blade edges while showcasing your collection.'
    when 'knife-sharpening-tools'
      assign seo_keywords = 'knife sharpening, whetstones, sharpening stones, honing steel, knife maintenance, Japanese whetstones'
      assign seo_description = 'Professional knife sharpening whetstones and tools. Maintain razor-sharp edges on all your knives.'
    when 'accessories'
      assign seo_keywords = 'knife accessories, knife sheaths, knife roll bags, kitchen accessories, knife care, knife protection'
      assign seo_description = 'Premium knife accessories including sheaths, roll bags, cutting boards, and sharpening tools.'
  endcase
  
  # Series collections
  if collection.handle contains '-series'
    assign series_name = collection.title | remove: 'Xinzuo ' | remove: ' Knives'
    assign seo_keywords = series_name | append: ' knives, Damascus steel, Japanese knives, chef knives, premium kitchen knives, hand-forged'
    assign seo_description = series_name | append: ' Damascus kitchen knives with exceptional craftsmanship. Hand-forged blades for superior performance.'
  endif
  
  # Use collection description if available
  if collection.description != blank
    assign seo_description = collection.description | strip_html | strip_newlines | truncate: 320
  endif
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": {{ canonical_url | json }},
  "name": {{ collection.title | json }},
  "url": {{ canonical_url | json }},
  "description": {{ seo_description | json }},
  "keywords": {{ seo_keywords | json }},
  "numberOfItems": {{ collection.products_count }},
  {%- if collection.image -%}
    "image": {{ collection.image | image_url: width: 1200 | prepend: "https:" | json }},
  {%- elsif collection.products.first.featured_image -%}
    "image": {{ collection.products.first.featured_image | image_url: width: 1200 | prepend: "https:" | json }},
  {%- endif -%}
  "isPartOf": {
    "@id": {{ shop.url | append: "#website" | json }}
  },
  "provider": {
    "@type": "Organization",
    "@id": {{ shop.url | append: "#organization" | json }}
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      {%- liquid
        assign bc_parent_name = ''
        assign bc_parent_url = ''
        if collection.handle contains '-series'
          assign bc_parent_name = 'Knives'
          assign bc_parent_url = '/collections/knives'
        elsif collection.handle contains 'under-'
          assign bc_parent_name = 'Knives'
          assign bc_parent_url = '/collections/knives'
        elsif collection.handle == 'cutting-boards' or collection.handle == 'chopping-boards' or collection.handle == 'whetstones' or collection.handle == 'knife-stands' or collection.handle == 'magnetic-knife-holders' or collection.handle == 'knife-guards' or collection.handle == 'knife-rolls' or collection.handle == 'kitchen-scissors' or collection.handle == 'aprons' or collection.handle == 'chef-aprons' or collection.handle == 'knife-sharpening-tools' or collection.handle == 'wood-knife-sheaths' or collection.handle == 'chef-knife-roll-bags'
          assign bc_parent_name = 'Accessories'
          assign bc_parent_url = '/collections/accessories'
        elsif collection.handle contains 'knife' or collection.handle contains 'knives'
          unless collection.handle == 'knives'
            assign bc_parent_name = 'Knives'
            assign bc_parent_url = '/collections/knives'
          endunless
        elsif collection.handle == 'cleavers' or collection.handle == 'chinese-cleaver' or collection.handle == 'carving-forks' or collection.handle == 'damascus'
          assign bc_parent_name = 'Knives'
          assign bc_parent_url = '/collections/knives'
        endif
      -%}
      {%- if bc_parent_name != '' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ bc_parent_name | json }},
        "item": {{ bc_parent_url | prepend: shop.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ collection.title | json }},
        "item": {{ collection.url | prepend: shop.url | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ collection.url | prepend: shop.url | json }}
      }
      {%- endif -%}
    ]
  },
  "mainEntity": {
    "@type": "ItemList",
    "name": {{ collection.title | append: " Products" | json }},
    "numberOfItems": {{ collection.products_count }},
    "itemListOrder": "https://schema.org/ItemListUnordered",
    "itemListElement": [
      {%- assign product_count = 0 -%}
      {%- for product in collection.products limit: 50 -%}
        {%- unless product.tags contains 'engraving-fee' -%}
          {%- liquid
            # Detect manufacturer brand (Xinzuo vs Hezhen) - mirrors the
            # detection in sections/product-information.liquid.
            assign mfr_brand = product.metafields.custom.manufacturer_brand
            if mfr_brand == blank
              assign h_lower = product.handle | downcase
              if h_lower contains 'hezhen' or h_lower contains 'supreme-series' or h_lower contains 'retro-series' or h_lower contains 'master-series' or h_lower contains 'flagship-series' or h_lower contains 'zhen-series' or h_lower contains 'pm8m' or h_lower contains 'pm8o' or h_lower contains 'pm8s'
                assign mfr_brand = 'Hezhen'
              else
                assign mfr_brand = 'Xinzuo'
              endif
            endif
          -%}
          {%- assign product_count = product_count | plus: 1 -%}
          {%- if product_count > 1 -%},{%- endif -%}
          {
            "@type": "ListItem",
            "position": {{ product_count }},
            "item": {
              "@type": "Product",
              "@id": {{ product.url | prepend: shop.url | append: "#product" | json }},
              "name": {{ product.title | json }},
              "url": {{ product.url | prepend: shop.url | json }},
              {%- if product.featured_image -%}
                "image": {{ product.featured_image | image_url: width: 800 | prepend: "https:" | json }},
              {%- endif -%}
              "description": {{ product.description | strip_html | strip_newlines | truncate: 200 | json }},
              "brand": {
                "@type": "Brand",
                "name": {{ mfr_brand | json }}
              },
              {%- if product.selected_or_first_available_variant.sku != blank -%}
                "sku": {{ product.selected_or_first_available_variant.sku | json }},
                "mpn": {{ product.selected_or_first_available_variant.sku | json }},
              {%- endif -%}
              "offers": {
                "@type": "Offer",
                "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
                "price": {{ product.price | divided_by: 100.0 }},
                {%- if product.compare_at_price > product.price -%}
                  {%- assign next_year = 'now' | date: '%Y' | plus: 1 -%}
                "priceValidUntil": "{{ next_year }}-12-31",
                {%- endif -%}
                "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
                "itemCondition": "https://schema.org/NewCondition",
                "url": {{ product.url | prepend: shop.url | json }},
                "seller": {
                  "@type": "Organization",
                  "name": {{ shop.name | json }}
                }
              }
              {%- if product.metafields.reviews.rating.value != blank -%}
                ,"aggregateRating": {
                  "@type": "AggregateRating",
                  "ratingValue": {{ product.metafields.reviews.rating.value.rating | json }},
                  "reviewCount": {{ product.metafields.reviews.rating_count | default: 1 }},
                  "bestRating": 5,
                  "worstRating": 1
                }
              {%- endif -%}
            }
          }
        {%- endunless -%}
      {%- endfor -%}
    ]
  }
}
</script>
{%- endif -%}

