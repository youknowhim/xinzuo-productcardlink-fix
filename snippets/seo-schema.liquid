{%- comment -%} FAQPage Schema for Homepage FAQs {%- endcomment -%}
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": {{ shop.url | append: "#homepage-faq" | json }},
  "mainEntity": [
    {
      "@type": "Question",
      "name": "You've got four main series. What's the actual difference?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Supreme (The Workhorse): Your durable, reliable first great knife. Retro (The Upgrade): A big step up. Stays seriously sharp, for longer. Mo (The Stunner): All the sharpness of the Upgrade, in a beautiful Damascus finish. LAN (The Pro): Our absolute best. Elite steel for an edge that just doesn't quit."
      }
    },
    {
      "@type": "Question",
      "name": "Is the wavy 'Damascus' pattern on the Mo and LAN series real?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oh, 100%. That's not a cheap laser-etch you'll see on knock-offs. It's the real, beautiful result of folding 67+ layers of steel over that high-performance core. It looks incredible, and it even helps food slide right off the blade. This is the real deal."
      }
    },
    {
      "@type": "Question",
      "name": "Can I put my knife in the dishwasher?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "That's the one hard 'no.' A dishwasher's high heat and harsh soap are brutal on a sharp blade and a beautiful handle. The simple fix: Just give it a 10-second hand wash with warm, soapy water right after use. Done."
      }
    },
    {
      "@type": "Question",
      "name": "Aren't these just 'Made in China' knives?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yep. They're made in Yangjiang, the 'Capital of Knives.' Here's a fun fact: Yangjiang has been mastering this craft for over 1,400 years. That's centuries before the famous hubs in Germany and Japan even got started. So we take world-class steel, send it to the city with the longest history of making world-class blades, and skip the legacy-brand markups. It's not just a good knife; it's a smart one."
      }
    },
    {
      "@type": "Question",
      "name": "What's the warranty? What if I don't like it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Easy. If it's not love at first slice, send it back within 30 days for a full refund. You're also covered by a lifetime warranty against manufacturing defects. And as a 100% Aussie company, you're always protected by Australian Consumer Law. We've got your back."
      }
    }
  ]
}
</script>
{%- endif -%}
