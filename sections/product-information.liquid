{% liquid
  assign product = closest.product

  if section.settings.desktop_media_position == 'left'
    assign render_order = 'media,product-details'
  else
    assign render_order = 'product-details,media'
  endif

  assign product_has_media = true
  if closest.product.media.size == 0
    assign product_has_media = false
  endif

  assign product_grid_class = 'product-information__grid'

  if product_has_media == false
    assign product_grid_class = product_grid_class | append: ' product-information--media-none'
  elsif section.settings.desktop_media_position == 'right'
    assign product_grid_class = product_grid_class | append: ' product-information--media-right'
  else
    assign product_grid_class = product_grid_class | append: ' product-information--media-left'
  endif

  if section.settings.equal_columns
    assign product_grid_class = product_grid_class | append: ' product-information__grid--half'

    if section.settings.limit_details_width
      assign product_grid_class = product_grid_class | append: ' product-information__grid--limit-details'
    endif
  endif

  case section.settings.content_width
    when 'content-center-aligned'
      assign content_width = 'page-width'
    when 'content-full-width'
      assign content_width = 'full-width'
  endcase
%}

{%- comment -%}
  ============================================
  SEO: Enhanced Product Schema with Rich Data
  ============================================
  Includes: aggregateRating, category, material, color, weight
{%- endcomment -%}
{%- liquid
  # Get Judge.me review data
  assign review_rating = product.metafields.reviews.rating.value.rating
  assign review_count = product.metafields.reviews.rating_count
  assign has_reviews = false
  if review_rating != blank and review_count != blank and review_count > 0
    assign has_reviews = true
  endif

  # Determine product category for schema
  assign product_category = 'Kitchen Knives'
  if product.type != blank
    assign product_category = product.type
  elsif product.tags contains 'knife'
    assign product_category = 'Kitchen Knives'
  elsif product.tags contains 'accessory' or product.tags contains 'accessories'
    assign product_category = 'Kitchen Accessories'
  elsif product.tags contains 'cutting-board' or product.tags contains 'chopping'
    assign product_category = 'Cutting Boards'
  elsif product.tags contains 'sharpening'
    assign product_category = 'Knife Sharpening Tools'
  endif

  # Get material from metafields or tags
  assign product_material = ''
  if product.metafields.custom.blade_material != blank
    assign product_material = product.metafields.custom.blade_material
  elsif product.tags contains 'damascus'
    assign product_material = 'Damascus Steel'
  elsif product.tags contains 'vg10' or product.tags contains 'vg-10'
    assign product_material = 'VG-10 Steel'
  elsif product.tags contains 'san-mai'
    assign product_material = 'San Mai Steel'
  elsif product.tags contains 'stainless'
    assign product_material = 'Stainless Steel'
  elsif product.tags contains 'high-carbon' or product.tags contains 'carbon steel'
    assign product_material = 'High Carbon Steel'
  endif

  # Get color from variant options
  assign product_color = ''
  for option in product.options_with_values
    assign option_name_lower = option.name | downcase
    if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'handle'
      assign product_color = option.values.first
      break
    endif
  endfor

  # Determine the actual manufacturer brand (Xinzuo vs Hezhen) for accurate
  # Product schema attribution. The Shopify vendor field is "Xinzuo Australia"
  # on every SKU because that is the Australian distributor entity, not the
  # manufacturer brand. Google's product knowledge graph needs the real brand
  # to match these products to the global Xinzuo and Hezhen entities.
  #
  # Detection: prefer an explicit metafield if set, otherwise infer from the
  # product handle. Hezhen series live under hezhen-, supreme-series,
  # retro-series, master-series, flagship-series, pm8m/pm8o/pm8s model codes,
  # or zhen-series in the handle. Default is Xinzuo.
  assign manufacturer_brand = product.metafields.custom.manufacturer_brand
  if manufacturer_brand == blank
    assign handle_lower = product.handle | downcase
    if handle_lower contains 'hezhen'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'supreme-series'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'retro-series'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'master-series'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'flagship-series'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'zhen-series'
      assign manufacturer_brand = 'Hezhen'
    elsif handle_lower contains 'pm8m' or handle_lower contains 'pm8o' or handle_lower contains 'pm8s'
      assign manufacturer_brand = 'Hezhen'
    else
      assign manufacturer_brand = 'Xinzuo'
    endif
  endif
-%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "@id": {{ canonical_url | append: "#product" | json }},
    "name": {{ product.title | json }},
    "url": {{ canonical_url | json }},
    "description": {{ product.description | strip_html | strip_newlines | truncate: 5000 | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ manufacturer_brand | json }}
    },
    "manufacturer": {
      "@type": "Organization",
      "name": {{ manufacturer_brand | json }},
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Yangjiang",
        "addressCountry": "CN"
      }
    },
    "category": {{ product_category | json }},
    {%- if product_material != blank -%}
      "material": {{ product_material | json }},
    {%- endif -%}
    {%- if product_color != blank -%}
      "color": {{ product_color | json }},
    {%- endif -%}
    {%- if product.featured_image -%}
      "image": [
        {%- for image in product.images limit: 20 -%}
          {{ image | image_url: width: 1200 | prepend: "https:" | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
    {%- endif -%}
    {%- comment -%} Product identifiers {%- endcomment -%}
    {%- if product.selected_or_first_available_variant.sku != blank -%}
      "sku": {{ product.selected_or_first_available_variant.sku | json }},
      "mpn": {{ product.selected_or_first_available_variant.sku | json }},
    {%- endif -%}
    {%- comment -%} Aggregate Rating from Judge.me {%- endcomment -%}
    {%- if has_reviews -%}
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": {{ review_rating | json }},
        "bestRating": 5,
        "worstRating": 1,
        "ratingCount": {{ review_count | json }},
        "reviewCount": {{ review_count | json }}
      },
    {%- endif -%}
    "offers": [
      {%- for v in product.variants -%}
        {%- liquid
          assign offer_url = product.url | within: collection | prepend: shop.url
          if v.id
            assign offer_url = offer_url | append: "?variant=" | append: v.id
          endif
          assign price_number = v.price | divided_by: 100.0
        -%}
        {
          "@type": "Offer",
          "name": {{ v.title | json }},
          "url": {{ offer_url | json }},
          "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
          "price": {{ price_number | json }},
          {%- if v.compare_at_price and v.compare_at_price > v.price -%}
            {%- assign next_year = 'now' | date: '%Y' | plus: 1 -%}
            "priceValidUntil": {{ next_year | append: '-12-31' | json }},
          {%- endif -%}
          "availability": "https://schema.org/{% if v.available %}InStock{% else %}OutOfStock{% endif %}",
          "itemCondition": "https://schema.org/NewCondition",
          "seller": {
            "@type": "Organization",
            "name": {{ shop.name | json }},
            "url": {{ shop.url | json }}
          },
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingDestination": {
              "@type": "DefinedRegion",
              "addressCountry": "AU"
            },
            "shippingRate": {
              "@type": "MonetaryAmount",
              "value": {% if v.price >= 10000 %}0{% else %}9.95{% endif %},
              "currency": "AUD"
            },
            "deliveryTime": {
              "@type": "ShippingDeliveryTime",
              "handlingTime": {
                "@type": "QuantitativeValue",
                "minValue": 1,
                "maxValue": 2,
                "unitCode": "DAY"
              },
              "transitTime": {
                "@type": "QuantitativeValue",
                "minValue": 2,
                "maxValue": 7,
                "unitCode": "DAY"
              }
            }
          },
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "AU",
            "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
            "merchantReturnDays": 30,
            "returnMethod": "https://schema.org/ReturnByMail",
            "returnFees": "https://schema.org/FreeReturn"
          }
          {%- if v.sku != blank -%}
            ,"sku": {{ v.sku | json }}
          {%- endif -%}
          {%- if v.barcode != blank -%}
            {%- if v.barcode.size == 12 -%},"gtin12": {{ v.barcode | json }}{%- endif -%}
            {%- if v.barcode.size == 13 -%},"gtin13": {{ v.barcode | json }}{%- endif -%}
            {%- if v.barcode.size == 14 -%},"gtin14": {{ v.barcode | json }}{%- endif -%}
          {%- endif -%}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ canonical_url | json }}
    }
  }
</script>

{%- comment -%} BreadcrumbList structured data for product pages {%- endcomment -%}
{%- liquid
  assign series_collection = null
  for coll in product.collections
    if coll.handle contains '-series'
      assign series_collection = coll
      break
    endif
  endfor
  if series_collection == null
    for coll in product.collections
      if coll.title contains 'Series'
        assign series_collection = coll
        break
      endif
    endfor
  endif
-%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {% if product.metafields.custom.isknife == true %}"Knives"{% else %}"Accessories"{% endif %},
        "item": {% if product.metafields.custom.isknife == true %}{{ shop.url | append: "/collections/knives" | json }}{% else %}{{ shop.url | append: "/collections/accessories" | json }}{% endif %}
      }{% if series_collection %},
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ series_collection.title | json }},
        "item": {{ shop.url | append: series_collection.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": {{ product.title | json }},
        "item": {{ canonical_url | json }}
      }{% else %},
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ canonical_url | json }}
      }{% endif %}
    ]
  }
</script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="product-information section section--{{ content_width }} spacing-style color-{{ section.settings.color_scheme }} relative"
  style="{% render 'spacing-style', settings: section.settings %} --gap: {{ section.settings.gap }}px;"
>
  {% if section.settings.desktop_media_position == 'left' and product_has_media %}
    {% assign product_href = '#ProductInformation-' | append: section.id %}
    {% render 'skip-to-content-link', href: product_href, text: 'accessibility.skip_to_product_info' %}
  {% endif %}
  <div
    class="{{ product_grid_class }}"
    data-product-grid-content
  >
    {% assign render_order_array = render_order | split: ',' %}
    {% capture media %}
      <div
        class="product-information__media"
        data-testid="product-information-media"
      >
        {%- content_for 'block',
          type: '_product-media-gallery',
          id: 'media-gallery',
          closest.product: closest.product
        -%}
      </div>
    {% endcapture %}

    {% capture details %}
      {% content_for 'block',
        type: '_product-details',
        id: 'product-details',
        closest.product: closest.product
      %}
    {% endcapture %}

    {% for block in render_order_array %}
      {% if block == 'media' and product_has_media %}
        {{ media }}
      {% elsif block == 'product-details' %}
        {{ details }}
      {% endif %}
    {% endfor %}
  </div>

  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .product-information {
    gap: var(--gap) 0;
  }

  /* Base grid layout */
  .product-information__grid {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
  }

  /* Default column positions */
  .product-details {
    order: 1;
  }

  .product-information__media {
    order: 0;
    width: 0;
    min-width: 100%;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .product-information__media {
      grid-column: 1 / -1;
    }

    .product-details {
      grid-column: 2 / 3;
    }
  }

  @media screen and (min-width: 1025px) {
    /* Position when there is media */
    .product-information__grid:not(:has(.product-information__media:empty)) {
      /* Media on the left side */
      &.product-information--media-left {
        grid-template-columns: minmax(0, 1fr) 400px;

        .product-information__media {
          padding-right: calc(var(--gap, 0) / 2);
        }

        .product-details {
          padding-left: calc(var(--gap, 0) / 2);
        }

        &:has(.media-gallery--extend) {
          grid-column: 1 / 3;
        }
      }

      /* Media on the right side */
      &.product-information--media-right {
        grid-template-columns: min(50vw, var(--sidebar-width)) 1fr;

        .product-information__media {
          padding-left: calc(var(--gap, 0) / 2);
          order: 1;
        }

        .product-details {
          padding-right: calc(var(--gap, 0) / 2);
          order: 0;
        }

        &:has(.media-gallery--extend) {
          grid-column: 2 / -1;
        }
      }

      /* Equal width columns */
      &.product-information__grid--half,
      &.product-information__grid--half:has(.media-gallery--extend) {
        grid-column: 1 / -1;
        grid-template-columns:
          var(--full-page-grid-margin) calc(var(--full-page-grid-central-column-width) / 2) calc(
            var(--full-page-grid-central-column-width) / 2
          )
          var(--full-page-grid-margin);

        &.product-information--media-left {
          .product-information__media {
            grid-column: 2 / 3;

            &:has(.media-gallery--extend) {
              grid-column: 1 / 3;
            }
          }

          .product-details {
            grid-column: 3 / 4;
          }
        }

        &.product-information--media-right {
          .product-information__media {
            grid-column: 3 / 4;

            &:has(.media-gallery--extend) {
              grid-column: 3 / -1;
            }
          }

          .product-details {
            grid-column: 2 / 3;
          }
        }
      }
    }
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    .product-information__grid {
      grid-column: 2;
    }

    /* Position when there is no media */
    .product-information__grid.product-information--media-none,
    .product-information__grid:has(.product-information__media:empty) {
      .product-details {
        width: var(--narrow-content-width);
        margin: 0 auto;
      }
    }

    /* Handle full width section */
    .section--full-width {
      .product-information__grid:not(:has(.product-information__media:empty)),
      .product-information__grid:not(:has(.product-information__media:empty)) {
        &.product-information--media-left,
        &.product-information--media-right {
          grid-column: 1 / -1;
        }

        &.product-information--media-left .product-details {
          padding-inline-end: var(--padding-lg);
        }

        &.product-information--media-right .product-details {
          padding-inline-start: var(--padding-lg);
        }

        &.product-information__grid--half.product-information--media-left {
          .product-information__media {
            grid-column: 1 / 3;
          }

          .product-details {
            grid-column: 3 / -1;
          }
        }

        &.product-information__grid--half.product-information--media-right {
          .product-information__media {
            grid-column: 3 / -1;
          }

          .product-details {
            grid-column: 1 / 3;
          }
        }
      }
    }
  }

  @media screen and (max-width: 1440px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      padding: 0px 47px;
    }
  }

  @media screen and (max-width: 950px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      padding: 0px;
    }
  }

  /* @media screen and (max-width: 750px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      padding: 0px;
    }
  } */

  /* Wider sidebar for large screens */
  @media screen and (min-width: 1400px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      grid-template-columns: 1fr 600px;
    }

    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-right {
      grid-template-columns: 1fr 2fr;
    }
  }

  .product-information__grid--limit-details .product-details > .group-block {
    max-width: var(--sidebar-width);
  }

  /* Cap the main gallery image height so it stays balanced with the details column */
  @media screen and (min-width: 1025px) {
    .product-information__media :not(.dialog-zoomed-gallery) > .product-media-container {
      max-height: calc(100vh - 200px);
    }
  }

  /* If the header is sticky, make product details content stick underneath the header */
  body:has(#header-group #header-component[data-sticky-state='active']) .product-details.sticky-content--desktop,
  body:has(#header-group #header-component[data-sticky-state='active']) .product-information__media .sticky-content,
  body:has(#header-group #header-component[data-sticky-state='active']) .product-information__media.sticky-content {
    --sticky-header-offset: var(--header-height);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_information",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "content-center-aligned",
          "label": "t:options.page"
        },
        {
          "value": "content-full-width",
          "label": "t:options.full"
        }
      ],
      "default": "content-center-aligned"
    },
    {
      "type": "select",
      "id": "desktop_media_position",
      "label": "t:settings.media_position",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "equal_columns",
      "label": "t:settings.equal_columns",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "limit_details_width",
      "label": "t:settings.limit_product_details_width",
      "default": false,
      "visible_if": "{{ section.settings.equal_columns }}"
    },
    {
      "type": "checkbox",
      "id": "is_knife",
      "label": "Knife",
      "default": true
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
