                    {% endif %}
                    {% if section.settings.col2_link5_label != blank %}
                        <li><a href="{{ section.settings.col2_link5_url }}">{{ section.settings.col2_link5_label }}</a></li>
                    {% endif %}
                </ul>
            </div>
            <div class="footer-seo-links__column">
                <h3>{{ section.settings.col3_heading }}</h3>
                <ul>
                    {% if section.settings.col3_link1_label != blank %}
