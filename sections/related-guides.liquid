{%- comment -%}
  Related Guides - Maps products to relevant blog articles
  using product tags (knife-type:*, series:*, blade-material:*).
  Also links to series comparison and maintenance guide pages.
{%- endcomment -%}

{%- liquid
  assign guide_handles = ''
  assign knife_type = ''
  assign series = ''
  assign is_damascus = false

  for tag in product.tags
    assign tl = tag | downcase | strip
    if tl contains 'knife-type:'
      assign knife_type = tl | split: ':' | last
    endif
    if tl contains 'series:'
      assign series = tl | split: ':' | last
    endif
    if tl == 'blade-material:damascus'
      assign is_damascus = true
    endif
  endfor

  assign pt = product.type | downcase

  # Accessories mapping
  if pt contains 'whetstone' or pt contains 'sharpening' or pt contains 'strop'
    assign guide_handles = 'how-to-sharpen-knives-whetstone,whetstone-grit-guide-kitchen-knives,knife-sharpening-angle-guide'
  elsif pt contains 'cutting board' or pt contains 'chopping board'
    assign guide_handles = 'chopping-board-guide-protect-kitchen-knives,end-grain-vs-edge-grain-cutting-boards,knife-care-daily-maintenance-guide'
  elsif pt contains 'magnetic' or pt contains 'holder' or pt contains 'knife block' or pt contains 'knife stand'
    assign guide_handles = 'magnetic-knife-holder-vs-knife-block,knife-care-daily-maintenance-guide,how-to-choose-a-chef-knife-the-complete-buying-guide'
  elsif pt contains 'knife roll'
    assign guide_handles = 'kitchen-knife-sets-vs-individual-knives,knife-care-daily-maintenance-guide,how-to-choose-a-chef-knife-the-complete-buying-guide'
  elsif pt contains 'apron'
    assign guide_handles = 'knife-care-daily-maintenance-guide,how-to-choose-a-chef-knife-the-complete-buying-guide,best-kitchen-knives-every-budget'
  elsif pt contains 'knife set'
    assign guide_handles = 'kitchen-knife-sets-vs-individual-knives,best-kitchen-knives-every-budget,knife-care-daily-maintenance-guide'
  elsif pt contains 'scissors'
    assign guide_handles = 'knife-care-daily-maintenance-guide,how-to-choose-a-chef-knife-the-complete-buying-guide,best-kitchen-knives-every-budget'
  elsif pt contains 'knife sheath' or pt contains 'knife guard'
    assign guide_handles = 'knife-care-daily-maintenance-guide,kitchen-knife-sets-vs-individual-knives,how-to-choose-a-chef-knife-the-complete-buying-guide'
  else
    # Knife type mapping
    case knife_type
      when 'chef' or 'gyuto'
        assign guide_handles = 'how-to-choose-a-chef-knife-the-complete-buying-guide,santoku-vs-chef-knife,knife-technique-rock-chop-push-cut-pull-slice'
      when 'santoku'
        assign guide_handles = 'santoku-vs-chef-knife,how-to-choose-a-chef-knife-the-complete-buying-guide,best-knife-vegetables-buying-guide'
      when 'nakiri'
        assign guide_handles = 'nakiri-knife-guide,best-knife-vegetables-buying-guide,vegetable-cleaver-vs-chef-knife-guide'
      when 'bunka'
        assign guide_handles = 'bunka-knife-guide-japanese-k-tip,japanese-knife-types-explained,knife-technique-rock-chop-push-cut-pull-slice'
      when 'carving' or 'slicing'
        assign guide_handles = 'carving-knife-guide,meat-carving-knife-guide,brisket-knife-guide-long-blades-bbq'
      when 'paring'
        assign guide_handles = 'paring-knife-buying-guide,knife-technique-rock-chop-push-cut-pull-slice,best-kitchen-knives-every-budget'
      when 'utility'
        assign guide_handles = 'utility-knife-buying-guide,petty-knife-guide-japanese-utility,knife-technique-rock-chop-push-cut-pull-slice'
      when 'boning'
        assign guide_handles = 'boning-knife-vs-fillet-knife-guide,fillet-knife-buying-guide,best-knife-meat-buying-guide'
      when 'fillet'
        assign guide_handles = 'fillet-knife-buying-guide,boning-knife-vs-fillet-knife-guide,sashimi-knife-buying-guide'
      when 'bread'
        assign guide_handles = 'bread-knife-guide,how-to-choose-a-chef-knife-the-complete-buying-guide,best-kitchen-knives-every-budget'
      when 'cleaver'
        assign guide_handles = 'cleaver-knife-guide-chinese-vs-western,vegetable-cleaver-vs-chef-knife-guide,best-knife-vegetables-buying-guide'
      when 'sujihiki'
        assign guide_handles = 'sujihiki-knife-guide,carving-knife-guide,sashimi-knife-buying-guide'
      when 'sashimi'
        assign guide_handles = 'sashimi-knife-buying-guide,sujihiki-knife-guide,japanese-knife-types-explained'
      when 'petty'
        assign guide_handles = 'petty-knife-guide-japanese-utility,utility-knife-buying-guide,paring-knife-buying-guide'
      else
        assign guide_handles = 'how-to-choose-a-chef-knife-the-complete-buying-guide,best-kitchen-knives-every-budget,knife-care-daily-maintenance-guide'
    endcase
  endif

  # Add series-specific article as first priority
  case series
    when 'lan'
      assign guide_handles = 'powder-steel-knife-guide-14cr14movnb,' | append: guide_handles
    when 'mo'
      assign guide_handles = '67-layer-vs-73-layer-damascus,' | append: guide_handles
    when 'retro'
      assign guide_handles = 'vg10-steel-vs-10cr15comov-guide,' | append: guide_handles
    when 'yu' or 'ji'
      assign guide_handles = 'beginner-kitchen-knife-buying-guide,' | append: guide_handles
  endcase

  # Add Damascus article for Damascus products
  if is_damascus
    assign guide_handles = guide_handles | append: ',real-damascus-steel-vs-fake'
  endif

  assign handles_array = guide_handles | split: ','
  assign shown = 0
  assign shown_handles = ''
  assign max_guides = 3

  # Determine if product is a knife (for maintenance/comparison links)
  assign is_knife = false
  if knife_type != blank
    assign is_knife = true
  elsif pt contains 'knife' and pt contains 'set'
    assign is_knife = true
  endif
-%}

{%- if handles_array.size > 0 -%}
{% style %}
  .section-{{ section.id }} .related-guides {
    padding: 48px 20px;
    margin-inline: calc(-1 * var(--page-margin, 16px) * 2);
    background: #1a1b22;
  }
  
  .section-{{ section.id }} .related-guides-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--page-margin, 20px);
  }

  @media screen and (max-width: 1025px) {
    .section-{{ section.id }} .related-guides {
      padding: 48px 80px;
    }

    .section-{{ section.id }} .related-guides-inner {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0px;
    }
  }

  @media screen and (max-width: 950px) {
    .section-{{ section.id }} .related-guides {
      padding: 48px 40px;
    }
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} {
      padding: 0px;
    }
  }

  .section-{{ section.id }} .related-guides h2 {
    font-family: "Sen", sans-serif;
    font-size: 40px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px;
  }
  .section-{{ section.id }} .related-guides .rg-subtitle {
    font-family: "Inter", sans-serif;
    font-size: 15px;
    color: #9a9aa0;
    margin: 0 0 32px;
  }
  .section-{{ section.id }} .rg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .section-{{ section.id }} .rg-card {
    background: #23242b;
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .section-{{ section.id }} .rg-card:hover {
    transform: translateY(-2px);
  }
  .section-{{ section.id }} .rg-card-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }
  .section-{{ section.id }} .rg-card-body {
    padding: 16px 20px 20px;
  }
  .section-{{ section.id }} .rg-card-title {
    font-family: "Sen", sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 8px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .section-{{ section.id }} .rg-card-cta {
    font-family: "Inter", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #c9c9cc;
    letter-spacing: 0.5px;
  }
  .section-{{ section.id }} .rg-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .section-{{ section.id }} .rg-links a {
    display: flex;
    align-items: center;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    color: #c9c9cc;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .section-{{ section.id }} .rg-links a:hover {
    color: #fff;
  }
  .section-{{ section.id }} .rg-links a svg {
    width: 14px;
    height: 14px;
    vertical-align: -2px;
    margin-right: 4px;
  }
  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .rg-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
      .section-{{ section.id }} .related-guides {
      padding: 48px 0px;
      width: 100%;
      margin: auto;
    }
    .section-{{ section.id }} .rg-card-img {
      height: 250px;
    }
    .section-{{ section.id }} .related-guides h2 {
      font-size: 22px;
    }
    .section-{{ section.id }} .rg-links {
      flex-direction: column;
      gap: 10px;
    }
  }
{% endstyle %}

<div class="section section-{{ section.id }}">
  <div class="related-guides">
    <div class="related-guides-inner">
      <h2>{{ section.settings.heading | default: 'Knife Knowledge' }}</h2>
      <p class="rg-subtitle">{{ section.settings.subtitle | default: 'Guides to help you get the most from your knife' }}</p>

      <div class="rg-grid">
        {%- for handle in handles_array -%}
          {%- if shown >= max_guides -%}{%- break -%}{%- endif -%}
          {%- assign handle_clean = handle | strip -%}
          {%- if handle_clean == blank -%}{%- continue -%}{%- endif -%}
          {%- if shown_handles contains handle_clean -%}{%- continue -%}{%- endif -%}
          {%- assign lookup = 'news/' | append: handle_clean -%}
          {%- assign art = articles[lookup] -%}
          {%- if art and art.published_at != blank -%}
            {%- assign shown_handles = shown_handles | append: handle_clean | append: ',' -%}
            {%- assign shown = shown | plus: 1 -%}
            <a href="{{ art.url }}" class="rg-card">
              {%- if art.image -%}
                <img class="rg-card-img" src="{{ art.image | image_url: width: 600, height: 320, crop: 'center' }}" alt="{{ art.title | escape }}" loading="lazy" width="600" height="320">
              {%- endif -%}
              <div class="rg-card-body">
                <p class="rg-card-title">{{ art.title }}</p>
                <span class="rg-card-cta">Read Guide &rarr;</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if is_knife -%}
      <div class="rg-links">
        {%- if series != blank -%}
          <a href="/pages/series-comparison">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2a.75.75 0 0 1 .75.75v4.5h4.5a.75.75 0 0 1 0 1.5h-4.5v4.5a.75.75 0 0 1-1.5 0v-4.5h-4.5a.75.75 0 0 1 0-1.5h4.5v-4.5A.75.75 0 0 1 8 2Z"/></svg>
            Compare all Xinzuo knife series
          </a>
        {%- endif -%}
        <a href="/pages/maintenance-guide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2a.75.75 0 0 1 .75.75v4.5h4.5a.75.75 0 0 1 0 1.5h-4.5v4.5a.75.75 0 0 1-1.5 0v-4.5h-4.5a.75.75 0 0 1 0-1.5h4.5v-4.5A.75.75 0 0 1 8 2Z"/></svg>
          Knife care and maintenance guide
        </a>
        <a href="/pages/warranty">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2a.75.75 0 0 1 .75.75v4.5h4.5a.75.75 0 0 1 0 1.5h-4.5v4.5a.75.75 0 0 1-1.5 0v-4.5h-4.5a.75.75 0 0 1 0-1.5h4.5v-4.5A.75.75 0 0 1 8 2Z"/></svg>
          Lifetime warranty details
        </a>
        <a href="/pages/faqs">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path d="M8 2a.75.75 0 0 1 .75.75v4.5h4.5a.75.75 0 0 1 0 1.5h-4.5v4.5a.75.75 0 0 1-1.5 0v-4.5h-4.5a.75.75 0 0 1 0-1.5h4.5v-4.5A.75.75 0 0 1 8 2Z"/></svg>
          Frequently asked questions
        </a>
      </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- endif -%}

{% schema %}
{
  "name": "Related Guides",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Knife Knowledge"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Guides to help you get the most from your knife"
    }
  ],
  "presets": [
    {
      "name": "Related Guides"
    }
  ]
}
{% endschema %}