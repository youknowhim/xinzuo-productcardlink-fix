{% style %}
    .section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        {% if section.settings.background_type == "color" %}
            background-color: #292a33 !important;
        {% elsif section.settings.background_type == "gradient" %}
        {% endif %}
    }

    .section-{{ section.id }} .product-info2 {
        display: flex;
        flex-direction: column;
        max-width: 1440px;
        margin: auto;
        gap: 80px;
    }

    @media screen and (max-width: 750px) {
        .section-{{ section.id }} .product-info2 {
            max-width: 100%;
            width: 100%;
        }
    }

    .section-{{ section.id }} .product-info2-header {
        width: 100%;
        max-width: 1440px;
        /* padding: 0 32px; */
        margin: auto;
    }

    .section-{{ section.id }} .product-info2-header div {
        max-width: 640px;
        {% if section.settings.header_type == "center" %}
            margin: auto;
        {% endif %}
    }

    .section-{{ section.id }} .product-info2-header p {
        font-family: "Sen";
        font-weight: 500;
        font-size: 18px;
        color: #fff;
        margin: 0;
        {% if section.settings.header_type == "center" %}
            text-align: center;
        {% endif %}
    }

    .section-{{ section.id }} .product-info2-header h2 {
        font-family: "Sen";
        font-weight: 600;
        font-size: 48px;
        color: #fff;
        line-height: 125%;
        margin: 0;
        {% if section.settings.header_type == "center" %}
            text-align: center;
        {% else %}
            margin-bottom: 48px;
        {% endif %}
    }

    .section-{{ section.id }} .product-info2-header span {
        font-family: "Inter";
        font-weight: 400;
        font-size: 18px;
        color: #c9c9cc;
    }

    .section-{{ section.id }} .product-info2 img {
        width: auto;
        height: auto;
    }

    @media screen and (min-width: 751px) {
        .section-{{ section.id }} .product-info2-main-image {
            {% if section.settings.image_width and section.settings.image_width > 0 %}
                width: {{ section.settings.image_width }}px !important;
            {% else %}
                width: auto !important;
            {% endif %}
            height: {{ section.settings.image_height | default: 440 }}px !important;
            max-width: 100%;
        }
    }

    @media screen and (max-width: 750px) {
        .section-{{ section.id }} .product-info2-main-image {
            {% if section.settings.image_width_mobile and section.settings.image_width_mobile > 0 %}
                width: {{ section.settings.image_width_mobile }}px !important;
            {% else %}
                width: 100% !important;
            {% endif %}
            height: auto !important;
            max-width: 100%;
        }
    }

    .section-{{ section.id }} .product-info2-footer1 {
        width: 100%;
        max-width: 1440px;
        padding: 64px 88px;
        margin: auto;
        background: linear-gradient(0deg, #0C0C0C 0%, #292A33 99.48%);
        display: flex;
        gap: 80px;
    }

    .section-{{ section.id }} .product-info2-footer1 .product-info2-left {
        padding-right: 80px;
    }

    .section-{{ section.id }} .product-info2-left h2 {
        font-family: "Sen";
        font-weight: 600;
        font-size: 36px;
        color: #fff;
        line-height: 135%;
        margin: 0;
    }

    .section-{{ section.id }} .product-info2-footer1 .product-info2-right {
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }

    .section-{{ section.id }} span {
        font-family: "Inter";
        font-weight: 400;
        font-size: 18px;
        color: #c9c9cc;
    }

    .section-{{ section.id }} .product-info2-footer2 {
        width: 100%;
        max-width: 1080px;
        margin: auto;
        /* padding: 0 32px; */
        display: flex;
        gap: 60px;
    }

    .section-{{ section.id }} .product-info2-footer2 .product-info2-left {
        width: 100%;
    }

    .section-{{ section.id }} .product-info2-footer2 .product-info2-left p {
        max-width: 480px;
    }

    .section-{{ section.id }} .product-info2-footer2 .product-info2-right p {
        margin: 10px 0 20px;
        color: #c9c9cc;
    }

    .section-{{ section.id }} .product-info2-footer2 .product-info2-right h2 {
        font-family: "Sen";
        font-weight: 600;
        font-size: 48px;
        color: #fff;
        margin: 0;
    }

    .section-{{ section.id }} .product-info2-footer3 {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 64px;
    }

    .section-{{ section.id }} .product-info2-footer3 > div {
        display: flex;
        gap: 64px;
        width: 100%;
        max-width: 1080px;
        margin: auto;
        padding: 24px 32px;
    }

    .section-{{ section.id }} .product-info2-footer3 img {
        width: 48px;
        height: 48px;
    }

    .section-{{ section.id }} .product-info2-footer2 img {
        width: 48px;
        height: 48px;
    }

    .section-{{ section.id }} .product-block-line {
        width: 100%;
        max-width: 320px;
        height: 1px;
        background: var(--xinzuo-accent, #FFD380);
        margin: 32px 0;
    }

    .section-{{ section.id }} strong {
        font-weight: 700;
        color: #fff;
    }

    .section-{{ section.id }} .product-info2-footer3 .product-info2-left {
        width: 50%;
    }

    .section-{{ section.id }} .product-info2-footer3 .product-info2-left span {
        max-width: 360px;
        display: block;
    }

    .section-{{ section.id }} .product-info2-footer3 .product-info2-right {
        width: 50%;
    }

    .section-{{ section.id }} .product-info2-footer3 .product-info2-right * {
        max-width: 360px;
        display: block;
    }

    .section-{{ section.id }} .product-info2-right a {
        font-family: "Inter";
        font-weight: 400;
        font-size: 18px;
        color: var(--xinzuo-accent, #FFD380);
        text-decoration: none;
        display: block;
        margin-top: 12px;
    }

    .section-{{ section.id }} .product-info2-img {
        display: flex;
        justify-content: space-between;
        gap: 64px;
        width: 100%;
    }
    
    {% if section.blocks.size > 0 %}
        .section-{{ section.id }} .product-info2 img {
            width: 50%;
            object-fit: cover;
        }

        .section-{{ section.id }} .product-info2-blocks {
            {% if section.settings.block_type == "text" %}
                padding: 64px 32px;
                width: 480px;
                gap: 64px;
                justify-content: center;
            {% else %}
                padding: 32px 48px 64px 32px;
                gap: 48px;
                width: calc(50% - 32px);
            {% endif %}
            display: flex;
            flex-direction: column;
        }

        @media screen and (min-width: 751px) {
            .section-{{ section.id }} .product-info2-img {
                align-items: stretch;
            }

            .section-{{ section.id }} .product-info2-main-image {
                width: calc(50% - 32px) !important;
                height: auto !important;
                align-self: stretch;
                object-fit: cover;
                max-width: none;
            }

            .section-{{ section.id }} .product-info2-blocks {
                width: calc(50% - 32px);
                justify-content: space-between;
            }
        }

        /* No image OR video → blocks/content span the full row */
        {% if section.settings.image_video == 'image' and section.settings.img == blank %}
            .section-{{ section.id }} .product-info2-img {
                flex-direction: column;
            }

            .section-{{ section.id }} .product-info2-blocks,
            .section-{{ section.id }} .product-info2 img {
                width: 100% !important;
            }

            @media screen and (min-width: 751px) {
                .section-{{ section.id }} .product-info2-blocks {
                    width: 100% !important;
                    padding: 0;
                }
            }
        {% endif %}
    {% endif %}

    {% comment %}
        No image AND no blocks → put header (left) and footer (right) on one row
        so the empty image space is filled by the footer content.
    {% endcomment %}
    {% if section.settings.image_video == 'image' and section.settings.img == blank and section.blocks.size == 0 and section.settings.footer_state == 'visible' %}
        /* Both viewports: header gets the same gradient card as the footer */
        .section-{{ section.id }} .product-info2-img {
            display: none;
        }

        .section-{{ section.id }} .product-info2-header {
            margin: 0;
            padding: 64px 88px;
            background: linear-gradient(0deg, #0C0C0C 0%, #292A33 99.48%);
        }

        .section-{{ section.id }} .product-info2-header div {
            max-width: none;
        }

        @media screen and (min-width: 751px) {
            .section-{{ section.id }} .product-info2 {
                display: grid;
                grid-template-columns: 1fr 1fr;
                column-gap: 64px;
                row-gap: 0;
                align-items: stretch;
            }

            .section-{{ section.id }} .product-info2-footer1,
            .section-{{ section.id }} .product-info2-footer2,
            .section-{{ section.id }} .product-info2-footer3 > div {
                margin: 0;
                max-width: none;
            }

            .section-{{ section.id }} .product-info2-footer1 {
                flex-direction: column;
                gap: 24px;
            }

            .section-{{ section.id }} .product-info2-footer1 .product-info2-left {
                padding-right: 0;
            }
        }

        @media screen and (max-width: 750px) {
            .section-{{ section.id }} .product-info2-header {
                padding: 32px 24px;
            }
        }
    {% endif %}

    /* Footer single-column: when one side is blank, the visible side spans full row */
    .section-{{ section.id }} .product-info2-footer1.product-info2-footer--single,
    .section-{{ section.id }} .product-info2-footer2.product-info2-footer--single,
    .section-{{ section.id }} .product-info2-footer3 > div.product-info2-footer--single {
        flex-direction: column;
        gap: 0;
    }

    .section-{{ section.id }} .product-info2-footer1.product-info2-footer--single .product-info2-left,
    .section-{{ section.id }} .product-info2-footer1.product-info2-footer--single .product-info2-right,
    .section-{{ section.id }} .product-info2-footer2.product-info2-footer--single .product-info2-left,
    .section-{{ section.id }} .product-info2-footer2.product-info2-footer--single .product-info2-right,
    .section-{{ section.id }} .product-info2-footer3 > div.product-info2-footer--single .product-info2-left,
    .section-{{ section.id }} .product-info2-footer3 > div.product-info2-footer--single .product-info2-right {
        width: 100%;
        max-width: none;
        padding-right: 0;
    }

    {% if section.settings.block_position == "side" %}
        .section-{{ section.id }} .product-info2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            column-gap: 64px;
            row-gap: 80px;
            align-items: start;
        }

        .section-{{ section.id }} .product-info2 > .product-info2-header {
            grid-column: 1 / -1;
        }

        .section-{{ section.id }} .product-info2-footer1,
        .section-{{ section.id }} .product-info2-footer2,
        .section-{{ section.id }} .product-info2-footer3 > div {
            flex-direction: column;
        }
    {% endif %}

    {% if section.blocks.size > 0 %}
        .section-{{ section.id }} .product-info2-block {
            {% if section.settings.block_type == "text" %}
                border-top: 1px solid var(--xinzuo-accent, #FFD380);
            {% else %}
                /* max-width: 360px; */
                width: 100%;
                margin: auto;
            {% endif %}
        }

        .section-{{ section.id }} .product-info2-block h2 {
            font-family: "Sen";
            font-weight: 600;
            font-size: 36px;
            color: #fff;
            line-height: 135%;
            margin: 0;
            padding: 16px 0;
        }

        .section-{{ section.id }} .product-info2-block img {
            width: 56px;
            height: 56px;
            margin-bottom: 24px;
        }

        .section-{{ section.id }} .product-info2-block span {
            font-family: "Inter";
            font-weight: 400;
            font-size: 18px;
            color: #c9c9cc;
            line-height: 150%;
        }
    {% endif %}

    {% if section.settings.additional_footer == true %}
        .section-{{ section.id }} .product-info2-left {
            max-width: 360px;
            margin-right: auto;
        }

        .section-{{ section.id }} .product-info2-right {
            max-width: 360px;
            margin-right: auto;
        }
    {% endif %}

    {% if section.settings.width == "full" %}
        .section-{{ section.id }} {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }
    {% endif %}

    @media screen and (max-width: 1025px) {
        .section-{{ section.id }} {
            padding: 48px 80px;
        }

        .section-{{ section.id }} .product-info2-blocks {
            padding: 0px;
        }

        .section-{{ section.id }} .product-info2 {
            gap: 48px;
        }

        .section-{{ section.id }} .product-info2-header h2 {
            {% if section.settings.header_type == "left" %}
                margin-bottom: 32px;
            {% endif %}
            font-size: 22px;
        }

        .section-{{ section.id }} .product-info2-header p {
            font-size: 16px;
        }

        .section-{{ section.id }} .product-info2-header span {
            font-size: 18px;
        }

        .section-{{ section.id }} .product-info2-footer1 {
            padding: 40px 32px;
        }

        .section-{{ section.id }} .product-info2-footer1 .product-info2-left {
            padding-right: 40px;
        }

        .section-{{ section.id }} .product-info2-footer2 .product-info2-right h2 {
            font-size: 28px;
        }

        {% if section.blocks.size > 0 %}
            .section-{{ section.id }} .product-info2-blocks {
                {% if section.settings.block_type == "text" %}
                    width: calc(100% - 400px);
                    padding: 20px 0;
                {% else %}
                    gap: 32px;
                {% endif %}
            }

            .section-{{ section.id }} .product-info2-block h2 {
                font-size: 22px;
            }

            .section-{{ section.id }} .product-info2-img {
                gap: 40px;
            }

            .section-{{ section.id }} .product-info2-block img {
                width: 48px;
                height: 48px;
                margin-bottom: 20px;
            }
        {% endif %}
    }

    @media screen and (max-width: 950px) {
        .section-{{ section.id }} {
            padding: 48px 0px;
        }
    }

    @media screen and (max-width: 750px) {
        .section-{{ section.id }} .product-info2-footer1 {
            flex-direction: column;
        }

        .section-{{ section.id }} {
            padding: 48px 0px;
        }

        .section-{{ section.id }} .product-info2-img {
            gap: 0;
        }

        .section-{{ section.id }} .product-info2-left {
            width: 100%;
        }

        .section-{{ section.id }} .product-info2-right {
            width: 100%;
        }

        .section-{{ section.id }} .product-info2-left h2 {
            font-size: 22px;
        }

        .section-{{ section.id }} .product-info2-footer1 {
            gap: 64px;
        }

        .section-{{ section.id }} .product-info2-footer2 {
            flex-direction: column;
            gap: 48px;
        }

        .section-{{ section.id }} .product-info2-footer3 > div {
            flex-direction: column;
            gap: 40px;
            padding: 0;
        }

        .section-{{ section.id }} .product-info2-footer3 .product-info2-left {
            width: 100%;
        }

        .section-{{ section.id }} .product-info2-footer3 .product-info2-right {
            width: 100%;
        }

        .section-{{ section.id }} .product-info2-img {
            flex-direction: column;
        }

        {% if section.settings.block_position == "side" %}
            .section-{{ section.id }} .product-info2 {
                grid-template-columns: 1fr;
            }
        {% endif %}

        {% if section.blocks.size > 0 %}
            .section-{{ section.id }} .product-info2 img {
                width: 100%;
            }

            .section-{{ section.id }} .product-info2-blocks {
                width: 100%;
            }

            .section-{{ section.id }} .product-info2-block img {
                width: 48px;
            }
        {% endif %}
    }

    /* @media screen and (max-width: 750px) {
        .section-{{ section.id }} {
            padding: 48px 15px;
        }
    } */

    /* Lazy-loaded video placeholder. Sized via aspect-ratio so the page does
       not jump when the actual <video> swaps in. */
    .product-info2-lazy-video {
        position: relative;
        width: 100%;
        background: #000;
        overflow: hidden;
    }
    .product-info2-lazy-video__poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .product-info2-lazy-video video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .product-info2-lazy-video[data-loaded] .product-info2-lazy-video__poster {
        display: none;
    }
{% endstyle %}

{%- comment -%}
  IntersectionObserver-based lazy video loader. Loaded once per page; safe if
  the section repeats. Falls back to immediate load on browsers without IO.
{%- endcomment -%}
<script>
  (function () {
    if (window.__productInfo2LazyVideoInit) return;
    window.__productInfo2LazyVideoInit = true;

    function activate(container) {
      if (container.dataset.loaded) return;
      var tpl = container.querySelector('template');
      if (!tpl) return;
      var frag = tpl.content.cloneNode(true);
      container.appendChild(frag);
      container.dataset.loaded = '1';
      var v = container.querySelector('video');
      if (v) {
        v.muted = true;
        v.setAttribute('playsinline', '');
        var p = v.play();
        if (p && typeof p.catch === 'function') { p.catch(function () {}); }
      }
    }

    function init() {
      var nodes = document.querySelectorAll('[data-lazy-video]');
      if (!nodes.length) return;
      if (!('IntersectionObserver' in window)) {
        // Older browser — load immediately rather than blocking the section.
        nodes.forEach(activate);
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            activate(e.target);
            io.unobserve(e.target);
          }
        });
      }, { rootMargin: '300px 0px', threshold: 0.01 });
      nodes.forEach(function (n) { io.observe(n); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section-{{ section.id }} section section--page-width color-{{ section.settings.color_scheme }}">
    <div class="product-info2">
        <div class="product-info2-header">
            <div>
                <p>{{ section.settings.heading_title }}</p>
                <span>{{ section.settings.heading_content }}</span>
                <span>{{ section.settings.heading_footer }}</span>
            </div>
        </div>
        {% if section.settings.image_video == "image" %}
            <div class="product-info2-img">
                {%- if section.settings.img != blank -%}
                    {% liquid
                        assign image = section.settings.img
                        assign image_alt = image.alt | default: section.settings.heading_title | default: 'Product information'
                        assign widths = '400, 600, 800, 1000, 1200'
                        assign sizes = '(min-width: 1025px) 50vw, (min-width: 750px) 50vw, 100vw'
                        assign loading = 'lazy'
                    %}
                    {{ image | image_url: width: 1200 | image_tag:
                        widths: widths,
                        sizes: sizes,
                        loading: loading,
                        alt: image_alt,
                        class: 'product-info2-main-image'
                    }}
                {%- endif -%}
                <div class="product-info2-blocks">
                    {% if section.blocks.size > 0 %}
                        {% for block in section.blocks %}
                            <div class="product-info2-block">
                                {% if section.settings.block_type == "text" %}
                                    <h2>{{ block.settings.heading }}</h2>
                                {% else %}
                                    {%- if block.settings.image != blank -%}
                                        {% liquid
                                            assign icon_image = block.settings.image
                                            assign icon_alt = icon_image.alt | default: block.settings.content | strip_html | truncate: 80 | default: 'Feature icon'
                                            assign icon_widths = '56, 112'
                                            assign icon_sizes = '56px'
                                        %}
                                        {{ icon_image | image_url: width: 112 | image_tag:
                                            widths: icon_widths,
                                            sizes: icon_sizes,
                                            loading: 'lazy',
                                            alt: icon_alt,
                                            width: 56,
                                            height: 56,
                                            class: 'product-info2-block-icon'
                                        }}
                                    {%- endif -%}
                                {% endif %}
                                <span>{{ block.settings.content }}</span>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        {% else %}
            {%- comment -%}
              Lazy-load the autoplay video to keep ~12 MB out of initial page render.
              The video element is held in <template> until the section enters the
              viewport, then swapped in by the IntersectionObserver below. Buyer
              experience is unchanged: video still autoplays muted+looped when they
              reach this section, just doesn't block initial load on PDP open.
            {%- endcomment -%}
            {%- liquid
              assign lv_video = section.settings.video
              assign lv_aspect = lv_video.aspect_ratio | default: 1.777
              assign lv_poster_alt = lv_video.alt | default: 'Product video'
              assign lv_poster_h = 1200 | divided_by: lv_aspect | round
            -%}
            {%- if lv_video != blank -%}
            <div class="product-info2-lazy-video" data-lazy-video style="aspect-ratio: {{ lv_aspect }};">
              {%- if lv_video.preview_image -%}
                {{ lv_video.preview_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '480, 720, 1080, 1440, 1920',
                    sizes: '100vw',
                    loading: 'lazy',
                    fetchpriority: 'low',
                    decoding: 'async',
                    alt: lv_poster_alt,
                    width: 1200,
                    height: lv_poster_h,
                    class: 'product-info2-lazy-video__poster'
                }}
              {%- endif -%}
              <template>{{ lv_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}</template>
            </div>
            {%- endif -%}
        {% endif %}
        {% if section.settings.footer_state == "visible" %}
            {%- liquid
                # Detect if either footer column is empty so the visible
                # side can span the full row instead of leaving a 50% gap.
                assign footer_single = false
                if section.settings.footer_left == blank or section.settings.footer_right == blank
                    assign footer_single = true
                endif
            -%}
            {% if section.settings.footer_type == "first" %}
                <div class="product-info2-footer1{% if footer_single %} product-info2-footer--single{% endif %}">
                    {% if section.settings.footer_left != blank %}
                        <span class="product-info2-left">{{ section.settings.footer_left }}</span>
                    {% endif %}
                    {% if section.settings.footer_right != blank %}
                        <span class="product-info2-right">{{ section.settings.footer_right }}</span>
                    {% endif %}
                </div>
            {% elsif section.settings.footer_type == "second" %}
                <div class="product-info2-footer2{% if footer_single and section.settings.additional_footer != true %} product-info2-footer--single{% endif %}">
                    {% if section.settings.additional_footer %}
                        <div class="product-info2-left">
                            {%- if section.settings.additional_image1 != blank -%}
                                {% liquid
                                    assign add_image1 = section.settings.additional_image1
                                    assign add_alt1 = add_image1.alt | default: section.settings.additional_content1 | strip_html | truncate: 80 | default: 'Product feature'
                                    assign add_widths = '48, 96'
                                    assign add_sizes = '48px'
                                %}
                                {{ add_image1 | image_url: width: 96 | image_tag:
                                    widths: add_widths,
                                    sizes: add_sizes,
                                    loading: 'lazy',
                                    alt: add_alt1,
                                    width: 48,
                                    height: 48,
                                    class: 'product-info2-additional-image'
                                }}
                            {%- endif -%}
                            <div class="product-block-line"></div>
                            <span>{{ section.settings.additional_content1 }}</span>
                        </div>
                        <div class="product-info2-right">
                            {%- if section.settings.additional_image2 != blank -%}
                                {% liquid
                                    assign add_image2 = section.settings.additional_image2
                                    assign add_alt2 = add_image2.alt | default: section.settings.additional_content2 | strip_html | truncate: 80 | default: 'Product feature'
                                    assign add_widths = '48, 96'
                                    assign add_sizes = '48px'
                                %}
                                {{ add_image2 | image_url: width: 96 | image_tag:
                                    widths: add_widths,
                                    sizes: add_sizes,
                                    loading: 'lazy',
                                    alt: add_alt2,
                                    width: 48,
                                    height: 48,
                                    class: 'product-info2-additional-image'
                                }}
                            {%- endif -%}
                            <div class="product-block-line"></div>
                            <span>{{ section.settings.additional_content2 }}</span>
                        </div>
                    {% else %}
                        {% if section.settings.footer_left != blank %}
                            <span class="product-info2-left">{{ section.settings.footer_left }}</span>
                        {% endif %}
                        {% if section.settings.footer_right != blank %}
                            <span class="product-info2-right">{{ section.settings.footer_right }}</span>
                        {% endif %}
                    {% endif %}
                </div>
            {% else %}
                <div class="product-info2-footer3">
                    <div{% if footer_single %} class="product-info2-footer--single"{% endif %}>
                        {% if section.settings.footer_left != blank %}
                            <div class="product-info2-left">
                                <span>{{ section.settings.footer_left }}</span>
                            </div>
                        {% endif %}
                        {% if section.settings.footer_right != blank %}
                            <div class="product-info2-right">
                                <span>{{ section.settings.footer_right }}</span>
                                {% comment %} <a>Learn more about {{ product.title }} ›</a> {% endcomment %}
                            </div>
                        {% endif %}
                    </div>
                    {% if section.settings.additional_footer %}
                        <div>
                            <div class="product-info2-left">
                                {%- if section.settings.additional_image1 != blank -%}
                                    {% liquid
                                        assign add_image1 = section.settings.additional_image1
                                        assign add_widths = '48, 96'
                                        assign add_sizes = '48px'
                                        # Robust alt fallback: image alt → derived from content → safe default.
                                        # Liquid's `default` filter does not always fire on empty strings from
                                        # Shopify image objects, so we use an explicit `blank` check.
                                        assign add_alt1 = add_image1.alt
                                        if add_alt1 == blank
                                            assign add_alt1 = section.settings.additional_content1 | strip_html | truncate: 80
                                        endif
                                        if add_alt1 == blank
                                            assign add_alt1 = 'Additional information'
                                        endif
                                    %}
                                    {{ add_image1 | image_url: width: 96 | image_tag:
                                        widths: add_widths,
                                        sizes: add_sizes,
                                        loading: 'lazy',
                                        alt: add_alt1,
                                        width: 48,
                                        height: 48,
                                        class: 'product-info2-additional-image'
                                    }}
                                {%- endif -%}
                                <div class="product-block-line"></div>
                                <span>{{ section.settings.additional_content1 }}</span>
                            </div>
                            <div class="product-info2-right">
                                {%- if section.settings.additional_image2 != blank -%}
                                    {% liquid
                                        assign add_image2 = section.settings.additional_image2
                                        assign add_widths = '48, 96'
                                        assign add_sizes = '48px'
                                        # Robust alt fallback (see add_alt1 above for rationale).
                                        assign add_alt2 = add_image2.alt
                                        if add_alt2 == blank
                                            assign add_alt2 = section.settings.additional_content2 | strip_html | truncate: 80
                                        endif
                                        if add_alt2 == blank
                                            assign add_alt2 = 'Additional information'
                                        endif
                                    %}
                                    {{ add_image2 | image_url: width: 96 | image_tag:
                                        widths: add_widths,
                                        sizes: add_sizes,
                                        loading: 'lazy',
                                        alt: add_alt2,
                                        width: 48,
                                        height: 48,
                                        class: 'product-info2-additional-image'
                                    }}
                                {%- endif -%}
                                <div class="product-block-line"></div>
                                <span>{{ section.settings.additional_content2 }}</span>
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        {% endif %}
    </div>
</section>

{% schema %}
{
