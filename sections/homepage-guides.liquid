{%- comment -%}
  Homepage Knife Knowledge - Shows key blog articles and collection links.
  Used on the homepage to drive traffic to educational content.
{%- endcomment -%}

{% style %}
  .section-{{ section.id }} .hg-wrap {
    padding: 56px 0;
    background: var(--xz-section-bg, #1A1A1E);
  }
  .section-{{ section.id }} .hg-inner {
    max-width: 1440px;
    margin: 0 auto;
    /* padding: 0 var(--page-margin, 16px); */
  }
  .section-{{ section.id }} .hg-wrap h2 {
    font-size: 48px;
    color: #fff;
    margin: 0 0 8px;
  }
  .section-{{ section.id }} .hg-subtitle {
    font-size: 15px;
    color: #9a9aa0;
    margin: 0 0 32px;
  }
  .section-{{ section.id }} .hg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }
  .section-{{ section.id }} .hg-card {
    background: var(--xz-card-bg, #292A33);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease;
    border-top: 2px solid var(--xinzuo-gold, #D1AE6B);
  }
  .section-{{ section.id }} .hg-card:hover {
    transform: translateY(-2px);
    border-top: 2px solid var(--xinzuo-gold, #D1AE6B);
  }
  .section-{{ section.id }} .hg-card-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }
  .section-{{ section.id }} .hg-card-body {
    padding: 16px 20px 20px;
  }
  .section-{{ section.id }} h3.hg-card-title {
    font-family: "Sen", sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 8px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .section-{{ section.id }} .hg-card-cta {
    font-size: 13px;
    font-weight: 600;
    color: #c9c9cc;
    letter-spacing: 0.5px;
  }
  .section-{{ section.id }} .hg-collections {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .section-{{ section.id }} .hg-collections a {
    font-size: 13px;
    font-weight: 600;
    color: #c9c9cc;
    text-decoration: none;
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    transition: all 0.2s ease;
  }
  .section-{{ section.id }} .hg-collections a:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }
  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .hg-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .section-{{ section.id }} .hg-wrap h2 { font-size: 28px; }
    .section-{{ section.id }} .hg-card-img { height: 120px; }
    .section-{{ section.id }} .hg-collections {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .section-{{ section.id }} .hg-collections a {
      font-size: 12px;
      padding: 8px 4px;
      text-align: center;
      white-space: nowrap;
    }
  }
{% endstyle %}

{%- assign guide_handles = 'how-to-choose-a-chef-knife-the-complete-buying-guide,real-damascus-steel-vs-fake,how-to-sharpen-knives-whetstone,japanese-knife-types-explained' | split: ',' -%}

<div class="section section-{{ section.id }}">
  <div class="hg-wrap">
    <div class="hg-inner">
      <h2>{{ section.settings.heading | default: 'Knife Knowledge' }}</h2>
      <p class="hg-subtitle">{{ section.settings.subtitle | default: 'Expert guides to help you choose, use, and care for your knives' }}</p>

      <div class="hg-grid">
        {%- for handle in guide_handles -%}
          {%- assign lookup = 'news/' | append: handle -%}
          {%- assign art = articles[lookup] -%}
          {%- if art and art.published_at != blank -%}
            <a href="{{ art.url }}" class="hg-card">
              {%- if art.image -%}
                <img class="hg-card-img" src="{{ art.image | image_url: width: 600, height: 320, crop: 'center' }}" alt="{{ art.title | escape }}" loading="lazy" width="600" height="320">
              {%- endif -%}
              <div class="hg-card-body">
                <h3 class="hg-card-title">{{ art.title }}</h3>
                <span class="hg-card-cta">Read Guide &rarr;</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="hg-collections">
        <a href="/collections/chef-knives">Chef Knives</a>
        <a href="/collections/damascus-knives">Damascus Knives</a>
        <a href="/collections/japanese-knives">Japanese Knives</a>
        <a href="/collections/knife-sets">Knife Sets</a>
        <a href="/collections/best-sellers">Best Sellers</a>
        <a href="/collections/whetstones">Whetstones</a>
        <a href="/pages/series-comparison">Compare Series</a>
        <a href="/pages/faqs">FAQs</a>
        <a href="/pages/reviews">Reviews</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Homepage Guides",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Knife Knowledge" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Expert guides to help you choose, use, and care for your knives" }
  ],
  "presets": [{ "name": "Homepage Guides" }]
}
{% endschema %}