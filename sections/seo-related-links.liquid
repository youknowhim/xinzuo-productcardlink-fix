{% comment %}
  SEO Related Links Section
  Displays internal links to related blog posts and sibling collections
  Renders nothing if no links are configured
{% endcomment %}

{%- if section.blocks.size > 0 -%}
{% style %}
  .section-{{ section.id }} .seo-related-links {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .section-{{ section.id }} .seo-related-links__heading {
    font-family: "Sen", sans-serif;
    font-weight: 600;
    font-size: 24px;
    color: #fff;
    margin: 0 0 24px 0;
    line-height: 1.3;
    text-align: center;
  }

  .section-{{ section.id }} .seo-related-links__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px 24px;
    margin: 0;
    padding: 0;
    list-style: none;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .seo-related-links__item {
    display: flex;
    align-items: flex-start;
  }

  .section-{{ section.id }} .seo-related-links__link {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: "Albert Sans", sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    color: #c9c9cc;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 8px 0;
  }

  .section-{{ section.id }} .seo-related-links__link:hover {
    color: #fff;
  }

  .section-{{ section.id }} .seo-related-links__link:hover .seo-related-links__arrow {
    transform: translateX(3px);
    color: #dc2626;
  }

  .section-{{ section.id }} .seo-related-links__arrow {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 3px;
    transition: transform 0.2s ease, color 0.2s ease;
    color: #666;
  }

  .section-{{ section.id }} .seo-related-links__text {
    flex: 1;
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .seo-related-links {
      padding: 32px 16px;
    }

    .section-{{ section.id }} .seo-related-links__heading {
      font-size: 20px;
      margin-bottom: 20px;
    }

    .section-{{ section.id }} .seo-related-links__list {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .section-{{ section.id }} .seo-related-links__link {
      font-size: 14px;
      padding: 10px 0;
    }
  }
{% endstyle %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section class="section-{{ section.id }} section color-{{ section.settings.color_scheme }}">
  <div class="seo-related-links">
    {%- if section.settings.heading != blank -%}
      <h2 class="seo-related-links__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <ul class="seo-related-links__list">
      {%- for block in section.blocks -%}
        {%- if block.settings.link_text != blank and block.settings.link_url != blank -%}
          <li class="seo-related-links__item" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link_url }}" class="seo-related-links__link">
              <svg class="seo-related-links__arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="seo-related-links__text">{{ block.settings.link_text }}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "SEO Related Links",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related Guides & Collections"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "SEO Related Links"
    }
  ]
}
{% endschema %}
