{% style %}
  .section-{{ section.id }} {
    /* background: linear-gradient(0deg, #0c0c0c, #292a33 99.48%); */
    background: var(--xz-section-bg, #1A1A1E);
    padding: 50px 20px 64px 20px;
    overflow: hidden;
  }

  .section-{{ section.id }} .best-reviews__header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 32px;
    padding: 0 16px;
  }

  .section-{{ section.id }} .best-reviews__header h2 {
    font-size: 48px;
    color: #fff;
    margin: 0 0 8px;
  }

  .section-{{ section.id }} .best-reviews__header h2 strong {
    color: #D1AE6B;
    font-weight: 600;
  }

  .section-{{ section.id }} .best-reviews__header p {
    font-weight: 400;
    font-size: 18px;
    color: #c9c9cc;
    margin: 0;
  }

  .section-{{ section.id }} .best-reviews__summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .section-{{ section.id }} .best-reviews__summary-stars {
    display: flex;
    gap: 2px;
  }

  .section-{{ section.id }} .best-reviews__summary-stars svg {
    width: 20px;
    height: 20px;
  }

  .section-{{ section.id }} .best-reviews__summary-text {
    font-weight: 400;
    font-size: 16px;
    color: #c9c9cc;
  }


  .section-{{ section.id }} .best-reviews-swiper {
    overflow: visible;
  }

  .section-{{ section.id }} .best-reviews-swiper .swiper-slide {
    height: auto;
  }

  .section-{{ section.id }} .review-card {
    background: #292a33;
    border-radius: 4px;
    border-top: 2px solid var(--xinzuo-gold, #D1AE6B);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .section-{{ section.id }} .review-card__stars {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
  }

  .section-{{ section.id }} .review-card__stars svg {
    width: 18px;
    height: 18px;
  }

  .section-{{ section.id }} .review-card__title {
    font-family: "Sen";
    font-weight: 600;
    font-size: 20px;
    color: #fff;
    margin: 0 0 12px;
    line-height: 140%;
  }

  .section-{{ section.id }} .review-card__body {
    font-weight: 400;
    font-size: 16px;
    color: #c9c9cc;
    line-height: 160%;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .section-{{ section.id }} .review-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 2px solid rgba(197, 165, 114, 0.2);
  }

  .section-{{ section.id }} .review-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: var(--xinzuo-accent, #FFD380);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-{{ section.id }} .review-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .review-card__avatar-initial {
    font-family: "Sen";
    font-weight: 600;
    font-size: 18px;
    color: #fff;
    line-height: 1;
  }

  .section-{{ section.id }} .review-card__author-info {
    display: flex;
    flex-direction: column;
  }

  .section-{{ section.id }} .review-card__name {
    font-family: "Sen";
    font-weight: 600;
    font-size: 15px;
    color: #fff;
    line-height: 1.3;
  }

  .section-{{ section.id }} .review-card__location {
    font-weight: 400;
    font-size: 13px;
    color: #828282;
    line-height: 1.3;
  }

  .section-{{ section.id }} .review-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
    font-size: 12px;
    color: white;
    margin-top: 4px;
  }

  .section-{{ section.id }} .review-card__verified svg {
    width: 14px;
    height: 14px;
  }

  .section-{{ section.id }} .best-reviews__slider-wrap {
    position: relative;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .best-reviews__cta {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-{{ section.id }} .best-reviews__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    color: #1a1a2e;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .section-{{ section.id }} .best-reviews__arrow:hover {
    background: #fff;
  }

  .section-{{ section.id }} .best-reviews__arrow.swiper-button-disabled {
    opacity: 0.3;
    cursor: default;
  }

  .section-{{ section.id }} .best-reviews__arrow svg {
    width: 20px;
    height: 20px;
  }

  .section-{{ section.id }} .best-reviews__arrow--prev {
    left: 0;
  }

  .section-{{ section.id }} .best-reviews__arrow--next {
    right: 0;
  }

  .section-{{ section.id }} .best-reviews__pagination {
    display: none;
  }

  .section-{{ section.id }} .best-reviews__cta {
    text-align: center;
    margin-top: 40px;
  }

  .section-{{ section.id }} .best-reviews__cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: "Sen", sans-serif;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--xinzuo-accent-text, #1A1A1E);
    background-color: var(--xinzuo-accent, #FFD380);
    border: none;
    border-radius: 4px;
    padding: 14px 32px;
    text-decoration: none;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .section-{{ section.id }} .best-reviews__cta a:hover {
    background-color: var(--xinzuo-accent-hover, #FFDC99);
    color: var(--xinzuo-accent-text, #1A1A1E);
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .best-reviews__cta a:active {
    background-color: var(--xinzuo-accent-active, #E5BC73);
    color: var(--xinzuo-accent-text, #1A1A1E);
    transform: translateY(0);
  }

  .section-{{ section.id }} .best-reviews__cta a svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .best-reviews__pagination {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 24px;
    }

    .section-{{ section.id }} .best-reviews__pagination .swiper-pagination-bullet {
      width: 8px;
      height: 8px;
      background: rgba(255, 255, 255, 0.25);
      border-radius: 50%;
      opacity: 1;
      transition: background 0.2s ease;
    }

    .section-{{ section.id }} .best-reviews__pagination .swiper-pagination-bullet-active {
      background: #fff;
    }
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} .best-reviews__arrow {
      display: none;
      width: 40px;
      height: 40px;
    }

    .section-{{ section.id }} .best-reviews__arrow svg {
      width: 16px;
      height: 16px;
    }
  }

  @media screen and (max-width: 750px) {
    .section-{{ section.id }} {
      padding: 32px 0 48px;
    }

    .section-{{ section.id }} .best-reviews__header {
      margin-bottom: 24px;
    }

    .section-{{ section.id }} .best-reviews__header h2 {
      font-size: 28px;
    }

    .section-{{ section.id }} .best-reviews__header p {
      font-size: 16px;
    }

    .section-{{ section.id }} .review-card {
      padding: 24px 20px;
    }

    .section-{{ section.id }} .review-card__title {
      font-size: 18px;
    }

    .section-{{ section.id }} .review-card__body {
      font-size: 15px;
    }

    .section-{{ section.id }} .best-reviews__summary {
      margin-bottom: 24px;
    }

    .section-{{ section.id }} .best-reviews__cta {
      margin-top: 28px;
      padding: 0 16px;
    }

    .section-{{ section.id }} .best-reviews__cta a {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}">
  <div class="best-reviews__header">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if section.settings.show_summary -%}
    <div class="best-reviews__summary">
      <div class="best-reviews__summary-stars">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24" fill="#D1AE6B" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
        {%- endfor -%}
      </div>
      {%- if section.settings.summary_text != blank -%}
        <span class="best-reviews__summary-text">{{ section.settings.summary_text }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="best-reviews__slider-wrap">
    <button class="best-reviews__arrow best-reviews__arrow--prev" aria-label="Previous review">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="best-reviews__arrow best-reviews__arrow--next" aria-label="Next review">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 6 15 12 9 18"/>
      </svg>
    </button>

    <div class="best-reviews-swiper swiper-container">
      <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="review-card">
            <div class="review-card__stars">
              {%- assign rating = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <svg viewBox="0 0 24 24" fill="#D1AE6B" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="#828282" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="review-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <p class="review-card__body">{{ block.settings.body }}</p>
            {%- endif -%}

            <div class="review-card__author">
              <div class="review-card__avatar">
                {%- if block.settings.avatar != blank -%}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 88 }}"
                    alt="{{ block.settings.name }}"
                    width="44"
                    height="44"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="review-card__avatar-initial">
                    {{- block.settings.name | slice: 0 | upcase -}}
                  </span>
                {%- endif -%}
              </div>
              <div class="review-card__author-info">
                {%- if block.settings.name != blank -%}
                  <span class="review-card__name">{{ block.settings.name }}</span>
                {%- endif -%}
                {%- if block.settings.location != blank -%}
                  <span class="review-card__location">{{ block.settings.location }}</span>
                {%- endif -%}
                {%- if block.settings.verified -%}
                  <span class="review-card__verified">
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                    Verified Buyer
                  </span>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
      </div>
    </div>
    <div class="best-reviews__pagination"></div>
  </div>

  <div class="best-reviews__cta">
    <a href="/pages/reviews">
      View All Reviews
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <g clip-path="url(#clip0_reviews_cta_{{ section.id }})">
          <path d="M5 15L15 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6.875 5H15V13.125" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
        <defs>
          <clipPath id="clip0_reviews_cta_{{ section.id }}">
            <rect width="20" height="20" fill="white"/>
          </clipPath>
        </defs>
      </svg>
    </a>
  </div>
</section>

<script>
  (function() {
    'use strict';

    var initialized = false;
    var sectionId = '{{ section.id }}';

    function initSwiper() {
      if (initialized) return;
      if (typeof Swiper === 'undefined') {
        setTimeout(initSwiper, 200);
        return;
      }

      var swiperEl = document.querySelector('.section-' + sectionId + ' .best-reviews-swiper');
      if (!swiperEl || swiperEl.classList.contains('swiper-initialized')) return;

      initialized = true;

      new Swiper(swiperEl, {
        slidesPerView: 1.15,
        spaceBetween: 16,
        slidesOffsetBefore: 16,
        grabCursor: true,
        loop: false,
        freeMode: true,
        navigation: {
          prevEl: '.section-' + sectionId + ' .best-reviews__arrow--prev',
          nextEl: '.section-' + sectionId + ' .best-reviews__arrow--next',
        },
        pagination: {
          el: '.section-' + sectionId + ' .best-reviews__pagination',
          clickable: true,
        },
        breakpoints: {
          750: {
            slidesPerView: 2.3,
            spaceBetween: 20,
            slidesOffsetBefore: 40,
          },
          950: {
            slidesPerView: 2.5,
            spaceBetween: 20,
            slidesOffsetBefore: 80,
          },
          1100: {
            slidesPerView: 3.3,
            spaceBetween: 24,
            slidesOffsetBefore: 80,
          },
          1400: {
            slidesPerView: 4.2,
            spaceBetween: 24,
            slidesOffsetBefore: 80,
          }
        }
      });
    }

    function observeSection() {
      var section = document.querySelector('.section-' + sectionId + ' .best-reviews-swiper');
      if (!section) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', observeSection);
        }
        return;
      }

      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              initSwiper();
              observer.disconnect();
            }
          });
        }, { rootMargin: '300px' });

        observer.observe(section);
      } else {
        initSwiper();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', observeSection);
    } else {
      observeSection();
    }
  })();
</script>

