{% style %}
    .section-{{ section.id }} footer {
        background: linear-gradient(180deg, #292A33 0%, #23242B 100%);
        padding: 48px 0 40px;
        margin-inline: calc(-1 * var(--page-margin, 16px) * 2);
    }

    .section-{{ section.id }} .footer-head {
        padding: 0 var(--page-margin, 16px);
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 640px;
        margin: 0 auto;
    }

    .section-{{ section.id }} .footer-head h2 {
        font-family: "Sen", sans-serif;
        font-weight: 600;
        font-size: 36px;
        color: white;
        margin: 0 0 12px;
        text-align: center;
        line-height: 1.3;
    }

    .section-{{ section.id }} .footer-head p {
        font-family: "Albert Sans", sans-serif;
        font-weight: 400;
        font-size: 16px;
        color: #c9c9cc;
        margin: 0;
        text-align: center;
        line-height: 1.5;
    }

    /* ── Email signup block ──
       Override Shopify's inline styles (from spacing-style/size-style snippets)
       and the block stylesheet's integrated-button absolute positioning.
       Use CSS grid (1fr auto) so input + button sit side-by-side reliably. */
    .section-{{ section.id }} .email-signup-block {
        padding: 24px 0 0 !important;
        width: 100% !important;
        min-width: unset !important;
    }

    .section-{{ section.id }} .email-signup__form {
        padding: 0 !important;
    }

    /* Container: grid keeps input + button on one line */
    .section-{{ section.id }} .email-signup__input-group {
        display: grid !important;
        grid-template-columns: 1fr auto !important;
        position: relative;
        background: rgba(255, 255, 255, 0.06) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        border-radius: 6px !important;
        transition: border-color 0.2s ease;
        gap: 0 !important;
    }

    .section-{{ section.id }} .email-signup__input-group:focus-within {
        border-color: rgba(255, 255, 255, 0.25) !important;
    }

    /* Input: transparent, fills left column */
    .section-{{ section.id }} .email-signup__input {
        background: transparent !important;
        border: none !important;
        color: #fff !important;
        font-family: "Albert Sans", sans-serif;
        font-size: 15px;
        padding: 14px 16px !important;
    }

    .section-{{ section.id }} .email-signup__input::placeholder {
        color: #6b6b73;
    }

    /* Button: force back into grid flow (override block's absolute positioning),
       styled as a pill inside the container */
    .section-{{ section.id }} .email-signup__button {
        position: static !important;
        background: var(--xinzuo-accent, #FFD380) !important;
        color: var(--xinzuo-accent-text, #1A1A1E) !important;
        font-family: "Sen", sans-serif !important;
        font-weight: 600 !important;
        font-size: 13px !important;
        letter-spacing: 0.5px;
        padding: 0 24px !important;
        border: none !important;
        border-radius: 4px !important;
        cursor: pointer;
        transition: background 0.2s ease;
        white-space: nowrap;
        margin: 4px !important;
        width: auto !important;
        height: auto !important;
        text-shadow: none !important;
    }

    .section-{{ section.id }} .email-signup__button:hover {
        background: var(--xinzuo-accent-hover, #FFDC99) !important;
    }

    @media screen and (max-width: 750px) {
        .section-{{ section.id }} footer {
            padding: 40px 0 32px;
        }

        .section-{{ section.id }} .footer-head h2 {
            font-size: 28px;
        }

        .section-{{ section.id }} .footer-head p {
            font-size: 15px;
        }

        /* Keep side-by-side on mobile — override block's 1fr collapse */
        .section-{{ section.id }} .email-signup__input-group {
            grid-template-columns: 1fr auto !important;
        }

        .section-{{ section.id }} .email-signup__input {
            padding: 12px 14px !important;
            font-size: 14px;
        }

        .section-{{ section.id }} .email-signup__button {
            padding: 0 16px !important;
            font-size: 12px !important;
        }
    }
{% endstyle %}

<div class="section section-{{ section.id }} color-{{ section.settings.color_scheme }}">
    <footer>
        <div class="footer-head">
            <h2>{{ section.settings.heading }}</h2>
            <p>{{ section.settings.content }}</p>
            {% content_for 'blocks' %}
        </div>
    </footer>
</div>

{% schema %}
{
    "name": "Custom Footer",
    "tag": "footer",
    "blocks": [
        {
            "type": "_divider"
        },
        {
            "type": "@app"
        },
        {
            "type": "button"
        },
        {
            "type": "follow-on-shop"
        },
        {
            "type": "group"
        },
        {
            "type": "icon"
        },
        {
            "type": "image"
        },
        {
            "type": "menu"
        },
        {
            "type": "payment-icons"
        },
        {
            "type": "text"
        },
        {
            "type": "logo"
        },
        {
            "type": "jumbo-text"
        },
        {
            "type": "social-links"
        },
        {
            "type": "email-signup"
        }
    ],
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading"
        },
        {
            "type": "text",
            "id": "content",
            "label": "Content"
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "t:settings.color_scheme",
            "default": "scheme-1"
        }
    ],
    "presets": [
        {
            "name": "Custom Footer",
            "blocks": {
                "email-signup": {
                    "type": "group"
                }
            }
        }
    ]
}
{% endschema %}