<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
<!-- Start of Shoplift scripts -->
{% render 'shoplift' %}
<!-- End of Shoplift scripts -->

    {%- comment -%} Performance: Critical meta and preconnect FIRST {%- endcomment -%}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% comment %} Performance: Preload LCP product image — eliminates 1,438ms load delay {% endcomment %}
    {%- if request.path contains '/products/' and product.media.size > 0 -%}
      <link
        rel="preload"
        as="image"
        href="{{ product.media[0].preview_image | image_url: width: 1200 }}"
        imagesrcset="{{ product.media[0].preview_image | image_url: width: 352 }} 352w, {{ product.media[0].preview_image | image_url: width: 832 }} 832w, {{ product.media[0].preview_image | image_url: width: 1200 }} 1200w, {{ product.media[0].preview_image | image_url: width: 1920 }} 1920w"
        imagesizes="(min-width: 750px) calc(100vw - 25rem), 100vw"
        fetchpriority="high"
      >
    {%- endif -%}
    {%- if request.path contains '/collections/' and collection.products.size > 0 -%}
      {%- assign _first_product = collection.products[0] -%}
      {%- if _first_product.featured_media -%}
        <link
          rel="preload"
          as="image"
          href="{{ _first_product.featured_media.preview_image | image_url: width: 600 }}"
          imagesrcset="{{ _first_product.featured_media.preview_image | image_url: width: 240 }} 240w, {{ _first_product.featured_media.preview_image | image_url: width: 352 }} 352w, {{ _first_product.featured_media.preview_image | image_url: width: 480 }} 480w, {{ _first_product.featured_media.preview_image | image_url: width: 600 }} 600w"
          imagesizes="(max-width: 749px) 45vw, (max-width: 1199px) 30vw, 22vw"
          fetchpriority="high"
        >
      {%- endif -%}
    {%- endif -%}
    {%- if request.path == '/search' and search.results.size > 0 -%}
      {%- for _result in search.results limit: 1 -%}
        {%- if _result.featured_media -%}
          <link
            rel="preload"
            as="image"
            href="{{ _result.featured_media.preview_image | image_url: width: 600 }}"
            imagesrcset="{{ _result.featured_media.preview_image | image_url: width: 240 }} 240w, {{ _result.featured_media.preview_image | image_url: width: 352 }} 352w, {{ _result.featured_media.preview_image | image_url: width: 480 }} 480w, {{ _result.featured_media.preview_image | image_url: width: 600 }} 600w"
            imagesizes="(max-width: 749px) 45vw, (max-width: 1199px) 30vw, 22vw"
            fetchpriority="high"
          >
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} View transition render blocker - disabled for performance {% endcomment %}
    {% if request.design_mode %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'seo-schema' -%}

    {%- comment -%} SEO/Performance: DNS Prefetch and Preconnect {%- endcomment -%}
    {% unless template == 'index' %}
      <link rel="preconnect" href="https://monorail-edge.shopifysvc.com" crossorigin>
      <link rel="dns-prefetch" href="https://productreviews.shopifycdn.com">
      <link rel="dns-prefetch" href="https://judge.me">
    {% endunless %}

    {%- comment -%} Self-hosted Google Fonts (Albert Sans + Sen) — eliminates 2 third-party origins {%- endcomment -%}
    {%- render 'google-fonts' -%}

    {%- comment -%}
      PDP LCP image preload. The Mo Chef PDP trace showed the LCP image (the
      first product gallery image) wasn't discovered by the parser until ~4s
      into page load, then took ~30s to download on a Slow 4G profile because
      it was competing with concurrent images for bandwidth at parse-time.
      Preloading at the very top of <head> issues the request before the
      parser even reaches the <img> tag, dedicating bandwidth to the LCP
      element and getting it on screen materially faster.

      We use imagesrcset + imagesizes so the browser picks the right
      responsive variant at preload time (no wasted bytes).
    {%- endcomment -%}
    {%- if template.name == 'product' and product and product.featured_image -%}
      {%- liquid
        assign lcp_img = product.featured_image
        assign lcp_alt = lcp_img.alt | default: product.title | escape
      -%}
      <link
        rel="preload"
        as="image"
        href="{{ lcp_img | image_url: width: 832 }}"
        imagesrcset="{{ lcp_img | image_url: width: 240 }} 240w, {{ lcp_img | image_url: width: 352 }} 352w, {{ lcp_img | image_url: width: 832 }} 832w, {{ lcp_img | image_url: width: 1200 }} 1200w"
        imagesizes="(min-width: 95rem) 65rem, (min-width: 750px) calc(100vw - 25rem - 40px - 24px - 40px), 100vw"
        fetchpriority="high"
      >
    {%- endif -%}

    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {% unless request.design_mode %}
      {%- render 'defer-third-party' -%}
    {% endunless %}

    {{ content_for_header }}

    <link
      rel="preload"
      href="{{ 'swiper-bundle.min.css' | asset_url }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
      fetchpriority="low"
    >
    <noscript><link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}"></noscript>
    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

    {%- comment -%} Site-wide custom overrides — loaded on every page {%- endcomment -%}
    <link rel="stylesheet" href="{{ 'site-overrides.css' | asset_url }}">

    {%- comment -%} Judge.me review widget styles — only on pages with reviews {%- endcomment -%}
    {%- liquid
      assign needs_judgeme_css = false
      if template == 'index' or template.name == 'product' or template.name == 'collection' or template == 'list-collections'
        assign needs_judgeme_css = true
      elsif template.suffix == 'series-comparison' or template.suffix == 'best-sellers' or template.suffix == 'bundles' or template.suffix == 'reviews'
        assign needs_judgeme_css = true
      endif
    -%}
    {%- if needs_judgeme_css or request.design_mode -%}
      <link rel="preload" href="{{ 'judgeme-reviews.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
      <noscript><link rel="stylesheet" href="{{ 'judgeme-reviews.css' | asset_url }}"></noscript>
      <script src="{{ 'judgeme-card-enhancer.js' | asset_url }}" defer></script>
    {%- endif -%}

    {% comment %} Critical CSS: Prevent layout shift on product pages {% endcomment %}
    {% if request.path contains '/products/' %}
      <style>
        /* Prevent layout shift: Force correct mobile layout before JavaScript runs */
        @media screen and (max-width: 749px) {
          /* Hide desktop-only elements immediately */
          .mobile\:hidden,
          .hidden--mobile {
            display: none !important;
          }

          /* Override grid layout for thumbnails on mobile - force flow layout */
          slideshow-component:has(slideshow-controls[pagination-position='left']),
          slideshow-component:has(slideshow-controls[pagination-position='right']) {
            display: block !important;
            grid-template: none !important;
          }

          /* Force thumbnails to center position styling on mobile */
          slideshow-controls[thumbnails][pagination-position='left'],
          slideshow-controls[thumbnails][pagination-position='right'] {
            order: 0 !important;
            display: block !important;
            height: auto !important;
            min-height: 0 !important;
          }

          /* Force thumbnail container to horizontal scroll on mobile */
          slideshow-controls[thumbnails][pagination-position='left'] .slideshow-controls__thumbnails-container,
          slideshow-controls[thumbnails][pagination-position='right'] .slideshow-controls__thumbnails-container {
            overflow: auto hidden !important;
          }

          /* Force thumbnails to horizontal layout on mobile */
          slideshow-controls[thumbnails][pagination-position='left'] .slideshow-controls__thumbnails,
          slideshow-controls[thumbnails][pagination-position='right'] .slideshow-controls__thumbnails {
            flex-direction: row !important;
            padding-inline: var(--slideshow-thumbnails-padding-inline, var(--padding-sm)) !important;
            padding-block: var(--slideshow-thumbnails-padding-block, var(--padding-sm)) !important;
          }
        }
      </style>

      <script>
        const imageThumbnail = () => {
          const thumbnail = document.querySelector('slideshow-controls');
          if (thumbnail) {
            if (window.innerWidth > 750) {
              thumbnail.setAttribute('pagination-position', 'left');
            } else {
              thumbnail.setAttribute('pagination-position', 'center');
            }
          }
        };

        window.addEventListener('DOMContentLoaded', () => {
          imageThumbnail();
        });

        window.addEventListener('resize', imageThumbnail);
      </script>
    {% endif %}

    <script src="{{ 'custom.js' | asset_url }}" defer></script>
    <link rel="stylesheet" href="{{ 'custom.css' | asset_url }}">

    <script type="text/javascript">
      var __assign =
        (this && this.__assign) ||
        function () {
          return (__assign =
            Object.assign ||
            function (n) {
              for (var i, o = 1, d = arguments.length; o < d; o++)
                for (var l in (i = arguments[o])) Object.prototype.hasOwnProperty.call(i, l) && (n[l] = i[l]);
              return n;
            }).apply(this, arguments);
        };
      !(function () {
        var n, i, o, d;
        if (
          !(null === (n = null === window || void 0 === window ? void 0 : window.rep) || void 0 === n ? void 0 : n.on)
        ) {
          var l = __assign(
              {},
              null !==
                (o =
                  null === (i = null === window || void 0 === window ? void 0 : window.rep) || void 0 === i
                    ? void 0
